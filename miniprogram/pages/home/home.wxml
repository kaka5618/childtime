<view class="page home-page">
  <image class="scene-bg-img" src="{{sceneBgUrl}}" mode="aspectFill" />

  <view class="hero-section">
    <view class="home-ambient">
      <view class="ambient-cloud cloud-a"></view>
      <view class="ambient-cloud cloud-b"></view>
      <view class="energy-wave wave-a"></view>
      <view class="energy-wave wave-b"></view>
      <view class="floating-star star-a">★</view>
      <view class="floating-star star-b">★</view>
      <view class="flower flower-a">
        <view class="petal petal-top"></view>
        <view class="petal petal-right"></view>
        <view class="petal petal-bottom"></view>
        <view class="petal petal-left"></view>
        <view class="flower-core"></view>
      </view>
      <view class="flower flower-b">
        <view class="petal petal-top"></view>
        <view class="petal petal-right"></view>
        <view class="petal petal-bottom"></view>
        <view class="petal petal-left"></view>
        <view class="flower-core"></view>
      </view>
    </view>

    <view class="topbar">
      <view class="kid-card">
        <view class="kid-avatar-wrap">
          <image class="kid-avatar-img" src="/assets/ui/home-avatar-badge.png" mode="aspectFill" />
          <view class="kid-avatar-emoji">{{avatarEmoji}}</view>
        </view>
        <view>
          <view class="kid-name">{{greetingText}}</view>
          <view class="kid-note">{{greetingNote}}</view>
        </view>
      </view>
    </view>

    <view class="energy-title-pill">能量袋</view>
    <view class="energy-label">
      <view class="energy-spark spark-one">★</view>
      <view class="energy-spark spark-two">✦</view>
      <text>{{energyProgressText}}</text>
    </view>
    <view class="energy-tag">
      <view class="energy-tag-title">今日目标</view>
      <view class="energy-tag-text">{{dailyTargetMinutes}} 分钟</view>
    </view>
  </view>

  <view class="plan-panel">
    <view class="plan-tab">今日计划</view>
    <view class="bag-copy">
      <view class="bag-title">{{bagTitle}}</view>
      <view class="muted">完成任务会按预估时间为能量袋充能。</view>
    </view>
    <view class="next-action">{{nextActionText}}</view>
    <view wx:if="{{showThemeChip}}" class="theme-chip" bindtap="goThemeSelect">
      <view class="theme-dot" style="background: {{activeTheme.accent}};"></view>
      <text>当前收集：{{activeTheme.name}} · {{collectionProgress.owned}}/{{collectionProgress.total}}</text>
    </view>
    <view class="section-head">
      <view class="section-title">任务清单</view>
      <button class="small-btn primary-btn {{addButtonClass}}" bindtap="goAddTask">添加</button>
    </view>

    <view wx:if="{{emptyVisible}}" class="empty">
      <view class="empty-title">还没有任务</view>
      <view class="muted">添加今晚要完成的作业，能量袋就会开始等待充能。</view>
    </view>

    <scroll-view wx:else class="task-list" scroll-y="true" enable-flex="true" show-scrollbar="false">
      <view wx:for="{{tasks}}" wx:key="id" class="task {{item.taskClass}}" bindtap="goFocus" data-id="{{item.id}}">
        <view class="task-main">
          <image class="task-icon-img" src="{{item.taskIconPath}}" mode="aspectFill" />
          <view>
            <view class="task-name">{{item.name}}</view>
            <view class="muted">{{item.minutes}} 分钟</view>
          </view>
        </view>
        <view class="task-actions">
          <view class="task-status">{{item.statusText}}</view>
          <view class="edit-btn {{item.editButtonClass}}" catchtap="goEditTask" data-id="{{item.id}}">编辑</view>
        </view>
      </view>
    </scroll-view>

    <button wx:if="{{showPackButton}}" class="focus-now-btn" bindtap="goPack">
      <view class="focus-btn-star">★</view>
      <text>去开包</text>
    </button>

    <button wx:elif="{{showFocusButton}}" class="focus-now-btn" bindtap="goNextTask">
      <view class="focus-btn-star">★</view>
      <text>{{focusButtonText}}</text>
    </button>

    <button wx:elif="{{showAlbumButton}}" class="focus-now-btn secondary-action" bindtap="goAlbum">
      <view class="focus-btn-star">★</view>
      <text>查看收藏</text>
    </button>
  </view>

  <view class="bottom-dock">
    <view class="dock-btn active">计划</view>
    <view class="dock-btn" bindtap="goAlbum">收藏</view>
    <view class="dock-btn" bindtap="goSettings">设置</view>
  </view>

  <view wx:if="{{namePromptVisible}}" class="name-modal-mask">
    <view class="name-modal">
      <view class="name-modal-star">★</view>
      <view class="name-modal-title">怎么称呼你？</view>
      <input class="name-modal-input" maxlength="8" value="{{nameDraft}}" placeholder="例如：小星星" bindinput="onNameDraftInput" />
      <view class="name-modal-btn" bindtap="saveNamePrompt">保存</view>
    </view>
  </view>
</view>
