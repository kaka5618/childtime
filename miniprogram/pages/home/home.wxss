.home-page {
  position: relative;
  padding: 28rpx 24rpx 132rpx;
  background:
    radial-gradient(circle at 22% 10%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 24%),
    linear-gradient(180deg, #bfe8f5 0%, #eef9d9 42%, #fff5df 100%);
}

.topbar,
.section-head,
.task {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar {
  position: relative;
  z-index: 2;
}

.kid-card {
  display: flex;
  max-width: 440rpx;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 16rpx 10rpx 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  box-shadow: 0 10rpx 24rpx rgba(82, 117, 83, 0.12);
}

.kid-avatar-img {
  width: 58rpx;
  height: 58rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: #fff8e9;
  flex: none;
}

.kid-name {
  color: #263d31;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.kid-note {
  margin-top: 3rpx;
  color: #6d7d73;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
}

.eyebrow {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.14);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 12rpx;
  color: #263d31;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.icon-btn,
.small-btn {
  min-width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.28);
  background: rgba(255, 253, 247, 0.78);
  color: #4e7a60;
  font-size: 26rpx;
  font-weight: 800;
}

.icon-btn {
  min-width: 102rpx;
  border-radius: 999rpx;
}

.bag-panel {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  overflow: hidden;
  padding: 24rpx 24rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 247, 0.9), rgba(255, 246, 221, 0.88));
  box-shadow: 0 20rpx 42rpx rgba(122, 95, 51, 0.12);
  text-align: center;
}

.hero-label {
  display: inline-flex;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.28);
  color: #8a5d13;
  font-size: 22rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 8rpx;
  color: #263d31;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.energy-scene {
  position: relative;
  height: 520rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #bfe8f5;
}

.energy-scene-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.energy-label {
  position: absolute;
  right: 0;
  bottom: 168rpx;
  left: 0;
  z-index: 2;
  color: #263d31;
  font-size: 40rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 4rpx 0 rgba(255, 248, 218, 0.72);
}

.energy-tag {
  position: absolute;
  right: 74rpx;
  top: 218rpx;
  z-index: 2;
  width: 106rpx;
  padding: 12rpx 8rpx;
  border: 2rpx dashed rgba(138, 93, 19, 0.34);
  border-radius: 18rpx;
  background: rgba(255, 232, 190, 0.9);
  color: #8a5d13;
  transform: rotate(8deg);
}

.energy-tag-title {
  font-size: 20rpx;
  font-weight: 900;
}

.energy-tag-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.bag-copy {
  margin-top: 20rpx;
}

.bag-title,
.section-title,
.empty-title,
.task-name {
  font-weight: 900;
}

.bag-title {
  color: #263d31;
  font-size: 36rpx;
}

.next-action {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.24);
  color: #8a5d13;
  font-size: 25rpx;
  font-weight: 800;
}

.pack-btn,
.album-btn {
  margin-top: 28rpx;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 700;
}

.theme-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.summary-item {
  padding: 18rpx 8rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(122, 95, 51, 0.06);
}

.summary-value {
  color: #23332b;
  font-size: 28rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 4rpx;
  color: #748078;
  font-size: 21rpx;
}

.section-head {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.section-title {
  color: #263d31;
  font-size: 34rpx;
}

.empty {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.9);
}

.task-list {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.task {
  min-height: 104rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  background: rgba(255, 253, 247, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(122, 95, 51, 0.08);
}

.task.done {
  opacity: 0.72;
}

.task-main {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
}

.task-icon {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(245, 194, 107, 0.28);
  color: #8a5d13;
  font-size: 26rpx;
  font-weight: 900;
}

.task-name {
  max-width: 330rpx;
  overflow: hidden;
  color: #263d31;
  font-size: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-status {
  color: #7ba68c;
  font-weight: 900;
}

.task-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.edit-btn {
  width: 84rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.34);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.disabled-btn {
  opacity: 0.48;
}

.disabled-edit {
  opacity: 0.48;
}

.bottom-dock {
  position: fixed;
  right: 34rpx;
  bottom: 26rpx;
  left: 34rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(82, 117, 83, 0.18);
}

.dock-btn {
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #6d7d73;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.dock-btn.active {
  background: linear-gradient(180deg, #ffe184, #f5c26b);
  color: #7b4c00;
  box-shadow: 0 8rpx 16rpx rgba(245, 194, 107, 0.22);
}
