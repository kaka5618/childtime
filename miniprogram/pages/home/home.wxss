.home-page {
  position: relative;
  min-height: 100vh;
  padding: 0 0 220rpx;
  background: #eaf6c4;
  color: #3c2a18;
  font-family: "Comic Sans MS", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.scene-bg-img {
  position: absolute;
  top: -120rpx;
  right: 0;
  left: 0;
  z-index: 0;
  width: 100%;
  height: 1540rpx;
  opacity: 1;
}

.hero-section {
  position: relative;
  z-index: 2;
  height: 760rpx;
  overflow: hidden;
}

.topbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.kid-card {
  display: flex;
  max-width: 430rpx;
  align-items: center;
  gap: 14rpx;
  padding: 8rpx 22rpx 8rpx 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  background: rgba(255, 250, 235, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(80, 66, 46, 0.16);
}

.kid-avatar-img {
  width: 76rpx;
  height: 76rpx;
  flex: none;
  border: 4rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: #fff8e9;
}

.kid-name {
  color: #4a2a13;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow: 0 2rpx 0 rgba(255, 245, 213, 0.8);
}

.kid-note {
  margin-top: 4rpx;
  color: #8a6d58;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.15;
}

.icon-btn,
.small-btn {
  height: 64rpx;
  margin: 0;
  border: 2rpx solid rgba(123, 166, 140, 0.32);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.88);
  color: #4e7a60;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.icon-btn {
  min-width: 190rpx;
}

.energy-title-pill {
  position: absolute;
  top: 154rpx;
  left: 50%;
  z-index: 2;
  padding: 12rpx 44rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 238, 195, 0.9);
  color: #8a5d13;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 10rpx 20rpx rgba(138, 93, 19, 0.16);
  text-shadow: 0 2rpx 0 rgba(255, 248, 220, 0.9);
  transform: translateX(-50%);
}

.energy-label {
  position: absolute;
  right: 0;
  bottom: 286rpx;
  left: 0;
  z-index: 2;
  color: #4a2a13;
  font-size: 46rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 4rpx 0 rgba(255, 248, 218, 0.72);
}

.energy-tag {
  position: absolute;
  right: 128rpx;
  top: 294rpx;
  z-index: 2;
  width: 112rpx;
  padding: 12rpx 8rpx;
  border: 2rpx dashed rgba(138, 93, 19, 0.36);
  border-radius: 18rpx;
  background: rgba(255, 232, 190, 0.88);
  color: #8a5d13;
  text-align: center;
  transform: rotate(8deg);
}

.energy-tag-title {
  font-size: 20rpx;
  font-weight: 900;
}

.energy-tag-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.plan-panel {
  position: relative;
  z-index: 3;
  margin: 18rpx 28rpx 0;
  padding: 52rpx 22rpx 42rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 250, 235, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(80, 66, 46, 0.14);
}

.plan-tab {
  position: absolute;
  top: -34rpx;
  left: 44rpx;
  min-width: 188rpx;
  height: 66rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #b8df8e, #89c86b);
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 66rpx;
  text-align: center;
  box-shadow: 0 10rpx 18rpx rgba(91, 141, 70, 0.18);
  text-shadow: 0 3rpx 0 rgba(68, 126, 57, 0.2);
}

.bag-copy {
  text-align: center;
}

.bag-title,
.section-title,
.empty-title,
.task-name {
  font-weight: 900;
}

.bag-title {
  color: #263d31;
  font-size: 34rpx;
  text-shadow: 0 2rpx 0 rgba(255, 248, 218, 0.78);
}

.muted {
  color: #65756d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
}

.next-action {
  display: inline-flex;
  margin: 18rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.24);
  color: #8a5d13;
  font-size: 25rpx;
  font-weight: 900;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4e7a60;
  font-size: 23rpx;
  font-weight: 800;
}

.theme-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
}

.section-title {
  color: #263d31;
  font-size: 34rpx;
  text-shadow: 0 2rpx 0 rgba(255, 248, 218, 0.78);
}

.small-btn {
  min-width: 220rpx;
}

.empty {
  margin-top: 18rpx;
  padding: 34rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 253, 247, 0.9);
}

.empty-title {
  color: #263d31;
  font-size: 32rpx;
}

.task-list {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  overflow: hidden;
}

.task {
  box-sizing: border-box;
  display: flex;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 88rpx;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border: 2rpx solid rgba(245, 194, 107, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 8rpx 18rpx rgba(122, 95, 51, 0.08);
  overflow: hidden;
}

.task.done {
  opacity: 0.86;
}

.task-main {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  align-items: center;
  gap: 16rpx;
}

.task-main > view {
  min-width: 0;
}

.task-icon-img {
  width: 64rpx;
  height: 64rpx;
  flex: none;
  border-radius: 18rpx;
  background: rgba(255, 250, 244, 0.86);
  box-shadow: 0 6rpx 12rpx rgba(122, 95, 51, 0.12);
}

.task-name {
  max-width: 230rpx;
  overflow: hidden;
  color: #563418;
  font-size: 28rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  text-shadow: 0 1rpx 0 rgba(255, 248, 218, 0.76);
  white-space: nowrap;
}

.task-status {
  box-sizing: border-box;
  width: 132rpx;
  padding: 8rpx 8rpx;
  border: 1rpx solid rgba(245, 194, 107, 0.34);
  border-radius: 999rpx;
  background: rgba(255, 248, 225, 0.82);
  color: #8a5d13;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
}

.task-actions {
  display: flex;
  width: 196rpx;
  flex: none;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  overflow: hidden;
}

.edit-btn {
  box-sizing: border-box;
  display: flex;
  width: 58rpx;
  height: 48rpx;
  flex: none;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.3);
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(123, 166, 140, 0.16);
  color: #3f7056;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.disabled-btn,
.disabled-edit {
  opacity: 0.48;
}

.focus-now-btn {
  position: relative;
  z-index: 1;
  display: flex;
  width: 420rpx;
  height: 86rpx;
  margin: 22rpx auto 0;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffd85f, #ffb52f);
  color: #7b4c00;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 86rpx;
  box-shadow: 0 14rpx 26rpx rgba(194, 126, 24, 0.22);
}

.focus-now-btn.secondary-action {
  background: linear-gradient(180deg, #dff3c5, #a6d982);
  color: #3e6d31;
}

.focus-btn-star {
  display: flex;
  width: 50rpx;
  height: 50rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff5bf;
  color: #f4b200;
  font-size: 30rpx;
  line-height: 50rpx;
}

.bottom-dock {
  position: fixed;
  right: 34rpx;
  bottom: 26rpx;
  left: 34rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(82, 117, 83, 0.18);
}

.dock-btn {
  display: flex;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #6d7d73;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.dock-btn.active {
  background: linear-gradient(180deg, #ffe184, #f5c26b);
  color: #7b4c00;
  box-shadow: 0 8rpx 16rpx rgba(245, 194, 107, 0.22);
}
