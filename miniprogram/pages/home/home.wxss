.home-page {
  padding-bottom: 56rpx;
}

.topbar,
.section-head,
.task {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow {
  color: #7ba68c;
  font-size: 24rpx;
  font-weight: 600;
}

.title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.icon-btn,
.small-btn {
  min-width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.bag-panel {
  margin-top: 32rpx;
  padding: 32rpx;
  text-align: center;
}

.bag {
  position: relative;
  width: 220rpx;
  height: 260rpx;
  margin: 0 auto;
  overflow: hidden;
  border: 8rpx solid #7ba68c;
  border-radius: 46% 46% 36% 36%;
  background: #e9eef0;
}

.bag-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #f5c26b, #f08d6b);
  transition: height 240ms ease;
}

.bag.full {
  border-color: #f5c26b;
  box-shadow: 0 0 36rpx rgba(245, 194, 107, 0.7);
}

.bag.full .bag-fill {
  background: linear-gradient(180deg, #ffe27a, #f48fb1, #7ba68c);
}

.bag-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
}

.bag-copy {
  margin-top: 24rpx;
}

.bag-title,
.section-title,
.empty-title,
.task-name {
  font-weight: 700;
}

.bag-title {
  font-size: 34rpx;
}

.next-action {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.18);
  color: #8a5d13;
  font-size: 25rpx;
  font-weight: 800;
}

.pack-btn,
.album-btn {
  margin-top: 28rpx;
}

.reward-panel {
  margin-top: 24rpx;
  padding: 26rpx;
}

.reward-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.reward-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.reward-card {
  position: relative;
}

.reward-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  z-index: 6;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 238, 133, 0.94);
  color: #7b4c00;
  font-size: 18rpx;
  font-weight: 900;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 700;
}

.theme-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.summary-item {
  padding: 16rpx 8rpx;
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.58);
}

.summary-value {
  color: #23332b;
  font-size: 28rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 4rpx;
  color: #748078;
  font-size: 21rpx;
}

.section-head {
  margin-top: 36rpx;
}

.section-title {
  font-size: 32rpx;
}

.empty {
  margin-top: 20rpx;
  padding: 28rpx;
}

.task-list {
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.task {
  padding: 26rpx;
}

.task.done {
  opacity: 0.66;
}

.task-status {
  color: #7ba68c;
  font-weight: 700;
}

.task-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.edit-btn {
  width: 84rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.42);
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 22rpx;
  line-height: 48rpx;
}

.disabled-btn {
  opacity: 0.48;
}

.disabled-edit {
  opacity: 0.48;
}
