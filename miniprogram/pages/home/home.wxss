.home-page {
  position: relative;
  overflow: hidden;
  padding: 28rpx 24rpx 132rpx;
  background:
    radial-gradient(circle at 22% 10%, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 24%),
    linear-gradient(180deg, #bfe8f5 0%, #eef9d9 42%, #fff5df 100%);
}

.topbar,
.section-head,
.task {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar {
  position: relative;
  z-index: 2;
}

.kid-card {
  display: flex;
  max-width: 440rpx;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 16rpx 10rpx 10rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.82);
  box-shadow: 0 10rpx 24rpx rgba(82, 117, 83, 0.12);
}

.kid-avatar {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 50%;
  background: linear-gradient(145deg, #ffd98d, #f29faa);
  color: #7b4c00;
  font-size: 25rpx;
  font-weight: 900;
}

.kid-name {
  color: #263d31;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 1.2;
}

.kid-note {
  margin-top: 3rpx;
  color: #6d7d73;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.2;
}

.home-decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.candy-line {
  position: absolute;
  height: 18rpx;
  border-radius: 999rpx;
  opacity: 0.72;
}

.line-a {
  top: 116rpx;
  right: -44rpx;
  width: 176rpx;
  background: repeating-linear-gradient(90deg, #f29faa 0 24rpx, #fff7d9 24rpx 48rpx);
  transform: rotate(-18deg);
}

.line-b {
  top: 360rpx;
  left: -54rpx;
  width: 150rpx;
  background: repeating-linear-gradient(90deg, #7ba68c 0 22rpx, #fff7d9 22rpx 44rpx);
  transform: rotate(20deg);
}

.soft-star {
  position: absolute;
  color: #f5c26b;
  font-size: 36rpx;
  text-shadow: 0 8rpx 16rpx rgba(245, 194, 107, 0.28);
}

.star-a {
  top: 170rpx;
  left: 44rpx;
  transform: rotate(-12deg);
}

.star-b {
  top: 530rpx;
  right: 48rpx;
  color: #f29faa;
  transform: rotate(16deg);
}

.eyebrow {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.14);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 800;
}

.title {
  margin-top: 12rpx;
  color: #263d31;
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.icon-btn,
.small-btn {
  min-width: 128rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.28);
  background: rgba(255, 253, 247, 0.78);
  color: #4e7a60;
  font-size: 26rpx;
  font-weight: 800;
}

.icon-btn {
  min-width: 102rpx;
  border-radius: 999rpx;
}

.bag-panel {
  position: relative;
  z-index: 1;
  margin-top: 26rpx;
  overflow: hidden;
  padding: 24rpx 24rpx 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 247, 0.9), rgba(255, 246, 221, 0.88));
  box-shadow: 0 20rpx 42rpx rgba(122, 95, 51, 0.12);
  text-align: center;
}

.hero-label {
  display: inline-flex;
  padding: 7rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.28);
  color: #8a5d13;
  font-size: 22rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 8rpx;
  color: #263d31;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.energy-scene {
  position: relative;
  min-height: 340rpx;
  margin-top: 16rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, #afe2f2 0%, #d8f4e3 62%, #bfe49d 100%);
}

.scene-cloud {
  position: absolute;
  height: 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
}

.scene-cloud::before,
.scene-cloud::after {
  position: absolute;
  bottom: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  content: "";
}

.scene-cloud::before {
  left: 18rpx;
  width: 42rpx;
  height: 42rpx;
}

.scene-cloud::after {
  right: 18rpx;
  width: 52rpx;
  height: 52rpx;
}

.cloud-a {
  top: 42rpx;
  left: 38rpx;
  width: 134rpx;
}

.cloud-b {
  top: 84rpx;
  right: 34rpx;
  width: 118rpx;
  opacity: 0.76;
}

.scene-hill {
  position: absolute;
  bottom: -70rpx;
  border-radius: 50%;
  background: rgba(121, 185, 105, 0.78);
}

.hill-a {
  left: -60rpx;
  width: 330rpx;
  height: 170rpx;
}

.hill-b {
  right: -80rpx;
  width: 380rpx;
  height: 190rpx;
  background: rgba(102, 171, 106, 0.64);
}

.scene-house {
  position: absolute;
  right: 72rpx;
  bottom: 50rpx;
  width: 82rpx;
  height: 78rpx;
}

.house-roof {
  width: 0;
  height: 0;
  margin: 0 auto;
  border-right: 44rpx solid transparent;
  border-bottom: 36rpx solid #f29faa;
  border-left: 44rpx solid transparent;
}

.house-body {
  width: 72rpx;
  height: 48rpx;
  margin: 0 auto;
  border-radius: 10rpx 10rpx 14rpx 14rpx;
  background: #fff7d9;
  box-shadow: inset 0 -8rpx 0 rgba(245, 194, 107, 0.18);
}

.bag-stage {
  position: relative;
  z-index: 2;
  width: 260rpx;
  margin: 22rpx auto 0;
}

.bag-shadow {
  position: absolute;
  right: 28rpx;
  bottom: -10rpx;
  left: 28rpx;
  height: 26rpx;
  border-radius: 50%;
  background: rgba(80, 66, 46, 0.12);
}

.bag {
  position: relative;
  width: 224rpx;
  height: 264rpx;
  margin: 0 auto;
  overflow: hidden;
  border: 10rpx solid #7ba68c;
  border-radius: 46% 46% 36% 36%;
  background: linear-gradient(180deg, #f8fff6, #dfeee7);
  box-shadow: inset 0 -18rpx 28rpx rgba(78, 122, 96, 0.12);
}

.bag-knot {
  position: absolute;
  top: -24rpx;
  left: 50%;
  z-index: 3;
  width: 86rpx;
  height: 54rpx;
  border: 8rpx solid #7ba68c;
  border-bottom: 0;
  border-radius: 50% 50% 0 0;
  background: #fffdf7;
  transform: translateX(-50%);
}

.bag-gloss {
  position: absolute;
  top: 42rpx;
  left: 42rpx;
  z-index: 2;
  width: 42rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
  transform: rotate(16deg);
}

.bag-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, #ffe184, #f5b0c5, #8fc9a4);
  transition: height 240ms ease;
}

.bag.full {
  border-color: #f5c26b;
  box-shadow: 0 0 36rpx rgba(245, 194, 107, 0.7);
}

.bag.full .bag-fill {
  background: linear-gradient(180deg, #ffe27a, #f48fb1, #7ba68c);
}

.bag-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #263d31;
  font-size: 48rpx;
  font-weight: 900;
  text-shadow: 0 4rpx 0 rgba(255, 255, 255, 0.55);
}

.bag-copy {
  margin-top: 20rpx;
}

.bag-title,
.section-title,
.empty-title,
.task-name {
  font-weight: 900;
}

.bag-title {
  color: #263d31;
  font-size: 36rpx;
}

.next-action {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.24);
  color: #8a5d13;
  font-size: 25rpx;
  font-weight: 800;
}

.pack-btn,
.album-btn {
  margin-top: 28rpx;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.62);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 700;
}

.theme-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.summary-item {
  padding: 18rpx 8rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.12);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  box-shadow: 0 8rpx 18rpx rgba(122, 95, 51, 0.06);
}

.summary-value {
  color: #23332b;
  font-size: 28rpx;
  font-weight: 800;
}

.summary-label {
  margin-top: 4rpx;
  color: #748078;
  font-size: 21rpx;
}

.section-head {
  position: relative;
  z-index: 1;
  margin-top: 30rpx;
}

.section-title {
  color: #263d31;
  font-size: 34rpx;
}

.empty {
  position: relative;
  z-index: 1;
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.9);
}

.task-list {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 18rpx;
  margin-top: 20rpx;
}

.task {
  min-height: 104rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 20rpx;
  background: rgba(255, 253, 247, 0.92);
  box-shadow: 0 12rpx 24rpx rgba(122, 95, 51, 0.08);
}

.task.done {
  opacity: 0.72;
}

.task-main {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 16rpx;
}

.task-icon {
  display: flex;
  width: 54rpx;
  height: 54rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: rgba(245, 194, 107, 0.28);
  color: #8a5d13;
  font-size: 26rpx;
  font-weight: 900;
}

.task-name {
  max-width: 330rpx;
  overflow: hidden;
  color: #263d31;
  font-size: 30rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-status {
  color: #7ba68c;
  font-weight: 900;
}

.task-actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.edit-btn {
  width: 84rpx;
  height: 48rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.34);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.disabled-btn {
  opacity: 0.48;
}

.disabled-edit {
  opacity: 0.48;
}

.bottom-dock {
  position: fixed;
  right: 34rpx;
  bottom: 26rpx;
  left: 34rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(82, 117, 83, 0.18);
}

.dock-btn {
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  background: transparent;
  color: #6d7d73;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 58rpx;
}

.dock-btn.active {
  background: linear-gradient(180deg, #ffe184, #f5c26b);
  color: #7b4c00;
  box-shadow: 0 8rpx 16rpx rgba(245, 194, 107, 0.22);
}
