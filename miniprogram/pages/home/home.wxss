.home-page {
  position: relative;
  min-height: 100vh;
  padding: 0 0 220rpx;
  background: #eaf6c4;
  color: #3c2a18;
  font-family: "Comic Sans MS", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.scene-bg-img {
  position: absolute;
  top: -120rpx;
  right: 0;
  left: 0;
  z-index: 0;
  width: 100%;
  height: 1540rpx;
  opacity: 1;
}

.hero-section {
  position: relative;
  z-index: 2;
  height: 760rpx;
  overflow: hidden;
}

.home-ambient {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.ambient-cloud {
  position: absolute;
  width: 118rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow:
    34rpx -10rpx 0 8rpx rgba(255, 255, 255, 0.72),
    68rpx 0 0 0 rgba(255, 255, 255, 0.64);
}

.cloud-a {
  top: 154rpx;
  left: -120rpx;
  opacity: 0.82;
  animation: cloud-drift-a 16s linear infinite;
}

.cloud-b {
  top: 272rpx;
  right: -160rpx;
  opacity: 0.56;
  transform: scale(0.72);
  animation: cloud-drift-b 20s linear infinite;
}

.energy-wave {
  position: absolute;
  left: 50%;
  top: 365rpx;
  width: 360rpx;
  height: 220rpx;
  border: 4rpx solid rgba(255, 226, 101, 0.22);
  border-radius: 50%;
  opacity: 0;
  transform: translateX(-50%) scale(0.72);
}

.wave-a {
  animation: energy-wave 3.4s ease-out infinite;
}

.wave-b {
  animation: energy-wave 3.4s ease-out 1.7s infinite;
}

.floating-star {
  position: absolute;
  color: #ffe36b;
  font-size: 28rpx;
  line-height: 1;
  opacity: 0.8;
  text-shadow: 0 0 14rpx rgba(255, 226, 107, 0.72);
}

.star-a {
  top: 226rpx;
  left: 150rpx;
  animation: star-twinkle 2.8s ease-in-out infinite;
}

.star-b {
  top: 324rpx;
  right: 174rpx;
  animation: star-twinkle 2.8s ease-in-out 0.9s infinite;
}

.flower {
  position: absolute;
  width: 48rpx;
  height: 48rpx;
  transform-origin: 50% 100%;
  animation: flower-sway 3.2s ease-in-out infinite;
}

.flower-a {
  left: 70rpx;
  bottom: 114rpx;
}

.flower-b {
  right: 86rpx;
  bottom: 86rpx;
  transform: scale(0.82);
  animation: flower-sway-small 3.2s ease-in-out 0.8s infinite;
}

.petal,
.flower-core {
  position: absolute;
  border-radius: 50%;
}

.petal {
  width: 22rpx;
  height: 22rpx;
  background: #fff7ce;
}

.petal-top {
  top: 0;
  left: 13rpx;
}

.petal-right {
  top: 13rpx;
  right: 0;
}

.petal-bottom {
  bottom: 0;
  left: 13rpx;
}

.petal-left {
  top: 13rpx;
  left: 0;
}

.flower-core {
  top: 15rpx;
  left: 15rpx;
  width: 18rpx;
  height: 18rpx;
  background: #ffd45f;
}

.topbar {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.kid-card {
  display: flex;
  max-width: 430rpx;
  align-items: center;
  gap: 14rpx;
  padding: 8rpx 22rpx 8rpx 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 999rpx;
  background: rgba(255, 250, 235, 0.9);
  box-shadow: 0 10rpx 24rpx rgba(80, 66, 46, 0.16);
}

.kid-avatar-img {
  width: 76rpx;
  height: 76rpx;
  flex: none;
  border: 4rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: #fff8e9;
}

.kid-name {
  max-width: 300rpx;
  overflow: hidden;
  color: #4a2a13;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.15;
  text-overflow: ellipsis;
  text-shadow: 0 2rpx 0 rgba(255, 245, 213, 0.8);
  white-space: nowrap;
}

.kid-note {
  max-width: 300rpx;
  overflow: hidden;
  margin-top: 4rpx;
  color: #8a6d58;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.15;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.icon-btn,
.small-btn {
  height: 64rpx;
  margin: 0;
  border: 2rpx solid rgba(123, 166, 140, 0.32);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.88);
  color: #4e7a60;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 64rpx;
}

.icon-btn {
  min-width: 190rpx;
}

.energy-title-pill {
  position: absolute;
  top: 154rpx;
  left: 50%;
  z-index: 2;
  padding: 12rpx 44rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 238, 195, 0.9);
  color: #8a5d13;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  box-shadow: 0 10rpx 20rpx rgba(138, 93, 19, 0.16);
  text-shadow: 0 2rpx 0 rgba(255, 248, 220, 0.9);
  transform: translateX(-50%);
  animation: soft-float 3.6s ease-in-out infinite;
}

.energy-label {
  position: absolute;
  right: 0;
  bottom: 286rpx;
  left: 0;
  z-index: 2;
  color: #4a2a13;
  font-size: 46rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 4rpx 0 rgba(255, 248, 218, 0.72);
  animation: energy-glow 2.8s ease-in-out infinite;
}

.energy-label text {
  position: relative;
  z-index: 2;
}

.energy-spark {
  position: absolute;
  z-index: 1;
  color: #fff4a8;
  font-size: 28rpx;
  line-height: 1;
  opacity: 0;
  text-shadow: 0 0 14rpx rgba(255, 226, 122, 0.9);
  pointer-events: none;
}

.spark-one {
  top: -24rpx;
  left: 35%;
  animation: collect-spark-a 2.8s ease-in-out infinite;
}

.spark-two {
  right: 34%;
  bottom: -24rpx;
  animation: collect-spark-b 2.8s ease-in-out 0.7s infinite;
}

.energy-tag {
  position: absolute;
  right: 128rpx;
  top: 294rpx;
  z-index: 2;
  width: 112rpx;
  padding: 12rpx 8rpx;
  border: 2rpx dashed rgba(138, 93, 19, 0.36);
  border-radius: 18rpx;
  background: rgba(255, 232, 190, 0.88);
  color: #8a5d13;
  text-align: center;
  transform: rotate(8deg);
}

.energy-tag-title {
  font-size: 20rpx;
  font-weight: 900;
}

.energy-tag-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.plan-panel {
  position: relative;
  z-index: 3;
  margin: 18rpx 28rpx 0;
  padding: 52rpx 22rpx 42rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  background: rgba(255, 250, 235, 0.88);
  box-shadow: 0 18rpx 36rpx rgba(80, 66, 46, 0.14);
}

.plan-tab {
  position: absolute;
  top: -34rpx;
  left: 44rpx;
  min-width: 188rpx;
  height: 66rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #b8df8e, #89c86b);
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 66rpx;
  text-align: center;
  box-shadow: 0 10rpx 18rpx rgba(91, 141, 70, 0.18);
  text-shadow: 0 3rpx 0 rgba(68, 126, 57, 0.2);
}

.bag-copy {
  text-align: center;
}

.bag-title,
.section-title,
.empty-title,
.task-name {
  font-weight: 900;
}

.bag-title {
  color: #263d31;
  font-size: 34rpx;
  text-shadow: 0 2rpx 0 rgba(255, 248, 218, 0.78);
}

.muted {
  color: #65756d;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
}

.next-action {
  display: inline-flex;
  margin: 18rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(245, 194, 107, 0.24);
  color: #8a5d13;
  font-size: 25rpx;
  font-weight: 900;
}

.theme-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4e7a60;
  font-size: 23rpx;
  font-weight: 800;
}

.theme-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.section-head {
  display: grid;
  grid-template-columns: 1fr 240rpx 1fr;
  gap: 12rpx;
  align-items: center;
  margin-top: 24rpx;
}

.section-title {
  color: #263d31;
  font-size: 34rpx;
  text-shadow: 0 2rpx 0 rgba(255, 248, 218, 0.78);
}

.small-btn {
  width: 240rpx;
  min-width: 0;
  height: 70rpx;
  border-width: 3rpx;
  box-shadow: 0 8rpx 14rpx rgba(82, 117, 83, 0.14);
  font-size: 30rpx;
  line-height: 70rpx;
}

.empty {
  margin-top: 18rpx;
  padding: 34rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 253, 247, 0.9);
}

.empty-title {
  color: #263d31;
  font-size: 32rpx;
}

.task-list {
  display: block;
  max-height: 388rpx;
  margin-top: 16rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
  overflow-x: hidden;
}

.task {
  box-sizing: border-box;
  display: flex;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 88rpx;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx;
  border: 2rpx solid rgba(245, 194, 107, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 8rpx 18rpx rgba(122, 95, 51, 0.08);
  overflow: hidden;
}

.task + .task {
  margin-top: 12rpx;
}

.task.done {
  opacity: 0.86;
}

.task.done .task-icon-img {
  animation: task-complete-pop 1.8s ease-out 1;
}

.task-main {
  display: flex;
  min-width: 0;
  flex: 1 1 auto;
  align-items: center;
  gap: 16rpx;
}

.task-main > view {
  min-width: 0;
}

.task-icon-img {
  width: 64rpx;
  height: 64rpx;
  flex: none;
  border-radius: 18rpx;
  background: rgba(255, 250, 244, 0.86);
  box-shadow: 0 6rpx 12rpx rgba(122, 95, 51, 0.12);
}

.task-name {
  max-width: 230rpx;
  overflow: hidden;
  color: #563418;
  font-size: 28rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  text-shadow: 0 1rpx 0 rgba(255, 248, 218, 0.76);
  white-space: nowrap;
}

.task-status {
  box-sizing: border-box;
  width: 132rpx;
  padding: 8rpx 8rpx;
  border: 1rpx solid rgba(245, 194, 107, 0.34);
  border-radius: 999rpx;
  background: rgba(255, 248, 225, 0.82);
  color: #8a5d13;
  font-size: 20rpx;
  font-weight: 900;
  text-align: center;
}

.task-actions {
  display: flex;
  width: 196rpx;
  flex: none;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  overflow: hidden;
}

.edit-btn {
  box-sizing: border-box;
  display: flex;
  width: 58rpx;
  height: 48rpx;
  flex: none;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.3);
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(123, 166, 140, 0.16);
  color: #3f7056;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.disabled-btn,
.disabled-edit {
  opacity: 0.48;
}

.focus-now-btn {
  position: relative;
  z-index: 1;
  display: flex;
  width: 420rpx;
  height: 86rpx;
  margin: 22rpx auto 0;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffd85f, #ffb52f);
  color: #7b4c00;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 86rpx;
  box-shadow: 0 14rpx 26rpx rgba(194, 126, 24, 0.22);
}

.focus-now-btn.secondary-action {
  background: linear-gradient(180deg, #dff3c5, #a6d982);
  color: #3e6d31;
}

.focus-btn-star {
  display: flex;
  width: 50rpx;
  height: 50rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff5bf;
  color: #f4b200;
  font-size: 30rpx;
  line-height: 50rpx;
}

.bottom-dock {
  position: fixed;
  right: 34rpx;
  bottom: 26rpx;
  left: 34rpx;
  z-index: 10;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  padding: 12rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.94);
  box-shadow: 0 16rpx 34rpx rgba(82, 117, 83, 0.18);
}

.dock-btn {
  display: flex;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #6d7d73;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 58rpx;
  text-align: center;
}

.dock-btn.active {
  background: linear-gradient(180deg, #ffe184, #f5c26b);
  color: #7b4c00;
  box-shadow: 0 8rpx 16rpx rgba(245, 194, 107, 0.22);
}

@keyframes soft-float {
  0%,
  100% {
    transform: translateX(-50%) translateY(0);
  }

  50% {
    transform: translateX(-50%) translateY(-6rpx);
  }
}

@keyframes cloud-drift-a {
  0% {
    transform: translateX(0);
  }

  100% {
    transform: translateX(940rpx);
  }
}

@keyframes cloud-drift-b {
  0% {
    transform: translateX(0) scale(0.72);
  }

  100% {
    transform: translateX(-940rpx) scale(0.72);
  }
}

@keyframes energy-wave {
  0% {
    opacity: 0;
    transform: translateX(-50%) scale(0.72);
  }

  22% {
    opacity: 0.52;
  }

  100% {
    opacity: 0;
    transform: translateX(-50%) scale(1.16);
  }
}

@keyframes star-twinkle {
  0%,
  100% {
    opacity: 0.42;
    transform: scale(0.8) rotate(0);
  }

  50% {
    opacity: 1;
    transform: scale(1.12) rotate(12deg);
  }
}

@keyframes flower-sway {
  0%,
  100% {
    transform: rotate(-4deg);
  }

  50% {
    transform: rotate(5deg);
  }
}

@keyframes flower-sway-small {
  0%,
  100% {
    transform: scale(0.82) rotate(-4deg);
  }

  50% {
    transform: scale(0.82) rotate(5deg);
  }
}

@keyframes energy-glow {
  0%,
  100% {
    text-shadow: 0 4rpx 0 rgba(255, 248, 218, 0.72), 0 0 0 rgba(255, 220, 82, 0);
  }

  50% {
    text-shadow: 0 4rpx 0 rgba(255, 248, 218, 0.88), 0 0 22rpx rgba(255, 220, 82, 0.56);
  }
}

@keyframes collect-spark-a {
  0%,
  100% {
    opacity: 0;
    transform: translateY(20rpx) scale(0.6) rotate(0);
  }

  45% {
    opacity: 1;
    transform: translateY(-6rpx) scale(1) rotate(18deg);
  }
}

@keyframes collect-spark-b {
  0%,
  100% {
    opacity: 0;
    transform: translateY(-12rpx) scale(0.6) rotate(0);
  }

  45% {
    opacity: 1;
    transform: translateY(6rpx) scale(1) rotate(-18deg);
  }
}

@keyframes task-complete-pop {
  0% {
    transform: scale(1);
  }

  18% {
    transform: scale(1.12) rotate(-4deg);
  }

  38% {
    transform: scale(0.98) rotate(3deg);
  }

  100% {
    transform: scale(1);
  }
}

.name-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  background: rgba(48, 38, 28, 0.42);
}

.name-modal {
  position: relative;
  width: 560rpx;
  padding: 56rpx 42rpx 42rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 36rpx;
  background:
    linear-gradient(90deg, rgba(126, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 252, 238, 0.98), rgba(255, 244, 213, 0.98));
  background-size: 42rpx 42rpx, 100% 100%;
  box-shadow:
    0 24rpx 46rpx rgba(52, 38, 24, 0.26),
    inset 0 0 0 6rpx rgba(255, 255, 255, 0.34);
  text-align: center;
}

.name-modal-star {
  position: absolute;
  top: -34rpx;
  left: 50%;
  width: 68rpx;
  height: 68rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  background: #fff1ad;
  box-shadow: 0 9rpx 16rpx rgba(116, 79, 32, 0.16);
  color: #efb62b;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 68rpx;
  transform: translateX(-50%);
}

.name-modal-title {
  color: #5a3a20;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow: 0 3rpx 0 rgba(255, 246, 218, 0.9);
}

.name-modal-input {
  height: 84rpx;
  margin-top: 34rpx;
  padding: 0 26rpx;
  border: 3rpx solid rgba(123, 166, 140, 0.3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 5rpx 0 rgba(255, 244, 207, 0.64);
  color: #4a2a13;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
}

.name-modal-btn {
  display: flex;
  width: 330rpx;
  height: 82rpx;
  margin: 34rpx auto 0;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffe27a, #f6b846);
  box-shadow:
    0 10rpx 0 #cf8930,
    0 16rpx 24rpx rgba(125, 76, 29, 0.2),
    inset 0 5rpx 0 rgba(255, 250, 215, 0.82);
  color: #744818;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 82rpx;
}

.name-modal-btn::after {
  border: 0;
}
