.pack-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 44rpx 30rpx 52rpx;
  background:
    radial-gradient(circle at 18% 11%, rgba(255, 222, 119, 0.46), transparent 25%),
    radial-gradient(circle at 86% 7%, rgba(255, 172, 195, 0.36), transparent 26%),
    linear-gradient(180deg, #fff0bd 0%, #f7fbdf 42%, #dff2d7 100%);
  color: #5a3d22;
  text-align: center;
}

.pack-page::before {
  position: absolute;
  top: -80rpx;
  right: -160rpx;
  width: 390rpx;
  height: 390rpx;
  border-radius: 50%;
  background: rgba(255, 244, 193, 0.74);
  content: "";
}

.pack-page::after {
  position: absolute;
  right: -40rpx;
  bottom: 0;
  left: -40rpx;
  height: 250rpx;
  background:
    radial-gradient(circle at 14% 78%, #9ad07d 0 30rpx, transparent 32rpx),
    radial-gradient(circle at 88% 48%, #f7bd78 0 36rpx, transparent 38rpx),
    linear-gradient(180deg, rgba(170, 220, 132, 0), rgba(162, 214, 126, 0.62));
  content: "";
  pointer-events: none;
}

.page-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.glow-a {
  top: 260rpx;
  left: -130rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.36);
}

.glow-b {
  right: -120rpx;
  bottom: 250rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(255, 218, 126, 0.24);
}

.pack-stage,
.result-stage {
  position: relative;
  z-index: 1;
}

.top-copy,
.result-header {
  padding-top: 18rpx;
  text-shadow: 0 4rpx 0 rgba(255, 252, 231, 0.78);
}

.eyebrow {
  display: inline-flex;
  min-height: 48rpx;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: rgba(255, 249, 222, 0.84);
  box-shadow: 0 9rpx 18rpx rgba(122, 90, 48, 0.12);
  color: #79a76d;
  font-size: 25rpx;
  font-weight: 900;
}

.pack-title,
.result-title {
  margin-top: 20rpx;
  color: #6a4121;
  font-size: 50rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.15;
  text-shadow:
    0 4rpx 0 #fff5cf,
    0 10rpx 16rpx rgba(116, 73, 28, 0.14);
}

.muted,
.result-subtitle {
  margin: 14rpx auto 0;
  max-width: 540rpx;
  color: #7e6b55;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.45;
}

.treasure-stage {
  position: relative;
  min-height: 610rpx;
  margin-top: 38rpx;
}

.treasure-stage::before {
  position: absolute;
  right: 18rpx;
  bottom: 54rpx;
  left: 18rpx;
  height: 150rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(126, 91, 43, 0.22), rgba(126, 91, 43, 0));
  content: "";
}

.treasure-chest {
  position: relative;
  z-index: 4;
  width: 454rpx;
  height: 404rpx;
  margin: 92rpx auto 0;
  transform-origin: 50% 84%;
}

.chest-lid {
  position: absolute;
  top: 12rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 6;
  height: 156rpx;
  border: 8rpx solid #8b4d22;
  border-bottom: 0;
  border-radius: 58rpx 58rpx 18rpx 18rpx;
  background:
    radial-gradient(circle at 27% 30%, rgba(255, 247, 183, 0.9), transparent 22%),
    linear-gradient(180deg, #ffd96e 0%, #f2a646 58%, #c86b32 100%);
  box-shadow:
    0 16rpx 18rpx rgba(108, 65, 25, 0.2),
    inset 0 8rpx 0 rgba(255, 246, 178, 0.62),
    inset 0 -10rpx 0 rgba(123, 65, 31, 0.18);
  transform-origin: 50% 100%;
}

.chest-lid::before {
  position: absolute;
  top: 24rpx;
  right: 30rpx;
  left: 30rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: rgba(255, 237, 135, 0.56);
  content: "";
}

.lid-ridge {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  left: 24rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 19% 50%, #fff1a7 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 50% 50%, #fff1a7 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 81% 50%, #fff1a7 0 8rpx, transparent 9rpx),
    linear-gradient(180deg, #c4683a, #9d4e2a);
  box-shadow: 0 7rpx 8rpx rgba(82, 45, 21, 0.18);
}

.lid-gem {
  position: absolute;
  left: 50%;
  bottom: -42rpx;
  width: 82rpx;
  height: 82rpx;
  border: 6rpx solid #94511f;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 34%, #fff8bd, #f7bd35);
  box-shadow:
    0 8rpx 14rpx rgba(100, 56, 22, 0.22),
    0 0 28rpx rgba(255, 219, 87, 0.62),
    inset 0 -7rpx 0 rgba(184, 112, 26, 0.2);
  color: #fff8cb;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 72rpx;
  text-shadow: 0 4rpx 0 #c17a22;
  transform: translateX(-50%);
}

.chest-base {
  position: absolute;
  right: 0;
  bottom: 0;
  left: 0;
  height: 258rpx;
  overflow: hidden;
  border: 8rpx solid #82491f;
  border-radius: 28rpx 28rpx 48rpx 48rpx;
  background:
    radial-gradient(circle at 24% 48%, rgba(255, 221, 130, 0.56), transparent 24%),
    linear-gradient(180deg, #efad4e 0%, #d67a35 45%, #a95b2e 100%);
  box-shadow:
    0 34rpx 42rpx rgba(116, 74, 34, 0.26),
    inset 0 8rpx 0 rgba(255, 229, 143, 0.48),
    inset 0 -13rpx 0 rgba(93, 48, 24, 0.18);
}

.chest-base::before {
  position: absolute;
  top: 36rpx;
  right: -8rpx;
  left: -8rpx;
  height: 44rpx;
  border-top: 5rpx solid #83441e;
  border-bottom: 5rpx solid #83441e;
  background:
    radial-gradient(circle at 20% 50%, #fff2ad 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 50% 50%, #fff2ad 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 80% 50%, #fff2ad 0 8rpx, transparent 9rpx),
    linear-gradient(180deg, #cc6540, #9d4e2a);
  content: "";
}

.chest-band {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 50%;
  width: 56rpx;
  background: linear-gradient(180deg, rgba(255, 226, 115, 0.86), rgba(211, 134, 34, 0.78));
  box-shadow:
    -5rpx 0 0 rgba(116, 66, 29, 0.18),
    5rpx 0 0 rgba(116, 66, 29, 0.18);
  transform: translateX(-50%);
}

.chest-tag {
  position: absolute;
  top: 88rpx;
  right: -34rpx;
  z-index: 3;
  display: flex;
  width: 118rpx;
  height: 92rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx dashed rgba(126, 80, 40, 0.46);
  border-radius: 22rpx;
  background: #fff1bd;
  box-shadow: 0 10rpx 16rpx rgba(84, 50, 25, 0.18);
  color: #8b5a21;
  font-size: 33rpx;
  font-weight: 900;
  transform: rotate(8deg);
}

.chest-lock {
  position: absolute;
  top: 88rpx;
  left: 50%;
  z-index: 4;
  display: flex;
  width: 112rpx;
  height: 112rpx;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #8c4b1e;
  border-radius: 50%;
  background: radial-gradient(circle at 50% 35%, #fff8c8, #ffc740);
  box-shadow:
    0 0 34rpx rgba(255, 226, 92, 0.78),
    0 10rpx 16rpx rgba(82, 43, 18, 0.2),
    inset 0 -9rpx 0 rgba(189, 119, 28, 0.2);
  color: #fff9cf;
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 5rpx 0 #bd7624;
  transform: translateX(-50%);
}

.chest-shine {
  position: absolute;
  top: 104rpx;
  left: 52rpx;
  width: 94rpx;
  height: 150rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, rgba(255, 235, 155, 0.46), rgba(255, 255, 255, 0));
  transform: rotate(14deg);
}

.chest-light {
  position: absolute;
  top: 120rpx;
  left: 50%;
  z-index: 3;
  width: 330rpx;
  height: 260rpx;
  border-radius: 50%;
  background:
    radial-gradient(circle, rgba(255, 251, 172, 0.96) 0%, rgba(255, 217, 76, 0.6) 38%, rgba(255, 189, 44, 0) 72%);
  opacity: 0;
  transform: translateX(-50%) scale(0.38);
  pointer-events: none;
}

.gold-rays {
  position: absolute;
  top: 34rpx;
  left: 50%;
  z-index: 2;
  width: 520rpx;
  height: 390rpx;
  opacity: 0;
  transform: translateX(-50%);
  pointer-events: none;
}

.gold-ray {
  position: absolute;
  bottom: 36rpx;
  left: 50%;
  width: 34rpx;
  height: 310rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 253, 180, 0), rgba(255, 224, 77, 0.78), rgba(255, 253, 180, 0));
  filter: blur(2rpx);
  opacity: 0;
  transform-origin: 50% 100%;
}

.ray-a {
  transform: translateX(-50%) rotate(-36deg);
}

.ray-b {
  transform: translateX(-50%) rotate(-18deg);
}

.ray-c {
  transform: translateX(-50%) rotate(0);
}

.ray-d {
  transform: translateX(-50%) rotate(18deg);
}

.ray-e {
  transform: translateX(-50%) rotate(36deg);
}

.table-shadow {
  position: absolute;
  right: 140rpx;
  bottom: 58rpx;
  left: 140rpx;
  height: 32rpx;
  border-radius: 50%;
  background: rgba(116, 76, 38, 0.18);
  filter: blur(2rpx);
}

.burst {
  position: absolute;
  top: 210rpx;
  left: 50%;
  z-index: 1;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 253, 187, 0.98), rgba(255, 206, 82, 0.52) 48%, rgba(255, 206, 82, 0) 72%);
  opacity: 0;
  transform: translateX(-50%) scale(0.4);
  pointer-events: none;
}

.spark {
  position: absolute;
  z-index: 3;
  color: #fff4a8;
  font-size: 34rpx;
  line-height: 1;
  opacity: 0.72;
  text-shadow: 0 0 16rpx rgba(255, 226, 122, 0.9);
}

.spark-a {
  top: 132rpx;
  left: 17%;
}

.spark-b {
  top: 216rpx;
  right: 14%;
  color: #fff;
}

.spark-c {
  bottom: 146rpx;
  left: 22%;
  color: #ffd75a;
}

.spark-d {
  right: 26%;
  bottom: 102rpx;
  color: #ffb5c6;
}

.open-note {
  display: inline-flex;
  min-height: 56rpx;
  align-items: center;
  justify-content: center;
  padding: 0 28rpx;
  border: 2rpx dashed rgba(213, 155, 72, 0.42);
  border-radius: 999rpx;
  background: rgba(255, 250, 224, 0.68);
  color: #8b6a43;
  font-size: 24rpx;
  font-weight: 800;
}

.open-btn {
  position: relative;
  z-index: 2;
  display: flex;
  width: 460rpx;
  height: 92rpx;
  margin: 34rpx auto 0;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffe27a, #f6b846);
  box-shadow:
    0 12rpx 0 #cf8930,
    0 20rpx 30rpx rgba(125, 76, 29, 0.22),
    inset 0 5rpx 0 rgba(255, 250, 215, 0.82);
  color: #744818;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 92rpx;
}

.open-btn::after {
  border: 0;
}

.open-btn[disabled] {
  opacity: 0.86;
}

.btn-star {
  width: 56rpx;
  height: 56rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #fff3bc;
  color: #f0a629;
  font-size: 34rpx;
  line-height: 56rpx;
  text-shadow: none;
}

.bubble-pack .chest-base {
  background:
    radial-gradient(circle at 24% 48%, rgba(255, 221, 130, 0.56), transparent 24%),
    linear-gradient(180deg, #efad4e 0%, #d67a35 45%, #cf7294 100%);
}

.dino-pack .chest-base {
  background:
    radial-gradient(circle at 24% 48%, rgba(255, 224, 140, 0.5), transparent 24%),
    linear-gradient(180deg, #e1b76b 0%, #bd7f43 44%, #84aa5b 100%);
}

.mecha-pack .chest-base {
  background:
    radial-gradient(circle at 24% 48%, rgba(229, 247, 255, 0.5), transparent 24%),
    linear-gradient(180deg, #9ec3de 0%, #7297c8 44%, #8d86d9 100%);
}

.garden-pack .chest-base {
  background:
    radial-gradient(circle at 24% 48%, rgba(255, 235, 243, 0.48), transparent 24%),
    linear-gradient(180deg, #ffc7d9 0%, #e98fb3 44%, #8cc87b 100%);
}

.opening .treasure-chest {
  animation: chest-shake 920ms ease-in-out both;
}

.opening .chest-lid {
  animation: chest-lid-open 2400ms cubic-bezier(0.19, 0.72, 0.22, 1) 620ms both;
}

.opening .chest-light {
  animation: chest-light-bloom 2450ms ease-out 640ms both;
}

.opening .gold-rays {
  animation: rays-visible 2450ms ease-out 640ms both;
}

.opening .gold-ray {
  animation: ray-burst 2350ms ease-out 660ms both;
}

.opening .burst {
  animation: burst-open 2650ms ease-out 560ms both;
}

.opening .spark-a {
  animation: spark-float-a 2600ms ease-out 640ms both;
}

.opening .spark-b {
  animation: spark-float-b 2600ms ease-out 720ms both;
}

.opening .spark-c {
  animation: spark-float-c 2600ms ease-out 780ms both;
}

.opening .spark-d {
  animation: spark-float-d 2600ms ease-out 840ms both;
}

.result-stage {
  padding-top: 8rpx;
}

.result-board {
  position: relative;
  margin-top: 34rpx;
  padding: 60rpx 24rpx 34rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 34rpx;
  background:
    linear-gradient(90deg, rgba(139, 185, 132, 0.1) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 252, 235, 0.94), rgba(255, 247, 218, 0.94));
  background-size: 44rpx 44rpx, 100% 100%;
  box-shadow:
    0 22rpx 46rpx rgba(108, 78, 38, 0.18),
    inset 0 0 0 7rpx rgba(255, 255, 255, 0.42);
}

.result-board::before {
  position: absolute;
  top: 20rpx;
  right: 28rpx;
  left: 28rpx;
  height: 2rpx;
  background: repeating-linear-gradient(90deg, rgba(211, 161, 96, 0.34) 0, rgba(211, 161, 96, 0.34) 12rpx, transparent 12rpx, transparent 24rpx);
  content: "";
}

.result-board::after {
  position: absolute;
  right: 24rpx;
  bottom: 18rpx;
  left: 24rpx;
  height: 56rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(255, 215, 94, 0.18), rgba(255, 215, 94, 0));
  content: "";
  pointer-events: none;
}

.board-tape {
  position: absolute;
  z-index: 2;
  width: 132rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: rgba(255, 180, 192, 0.86);
  box-shadow: 0 8rpx 14rpx rgba(102, 73, 44, 0.12);
}

.tape-left {
  top: -18rpx;
  left: 46rpx;
  transform: rotate(-7deg);
}

.tape-right {
  top: -18rpx;
  right: 46rpx;
  background: rgba(255, 221, 128, 0.86);
  transform: rotate(7deg);
}

.reward-spark {
  position: absolute;
  z-index: 3;
  color: #f9c64b;
  font-size: 34rpx;
  line-height: 1;
  text-shadow: 0 0 14rpx rgba(255, 218, 90, 0.8);
  animation: reward-sparkle 2.4s ease-in-out infinite;
  pointer-events: none;
}

.spark-left {
  top: 28rpx;
  left: 26rpx;
}

.spark-right {
  right: 30rpx;
  bottom: 30rpx;
  color: #ff9fb7;
  animation-delay: 0.8s;
}

.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 30rpx 22rpx;
  perspective: 900rpx;
}

.reveal-title {
  animation: title-pop 360ms ease-out both;
}

.reveal-card {
  position: relative;
  overflow: visible;
  padding: 12rpx 12rpx 54rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.82);
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 248, 221, 0.72));
  box-shadow:
    0 12rpx 20rpx rgba(101, 75, 41, 0.12),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.72);
  opacity: 0;
  transform: translateY(44rpx) rotateY(78deg) scale(0.88);
  transform-origin: center;
  animation: card-reveal 760ms cubic-bezier(0.16, 0.9, 0.2, 1.2) both;
}

.reveal-card::after {
  position: absolute;
  right: 16rpx;
  bottom: 12rpx;
  color: rgba(245, 194, 107, 0.82);
  content: "★";
  font-size: 28rpx;
  line-height: 1;
  pointer-events: none;
}

.prize-aura {
  position: absolute;
  top: -20rpx;
  right: -16rpx;
  bottom: 18rpx;
  left: -16rpx;
  z-index: -1;
  border-radius: 30rpx;
  background: radial-gradient(ellipse at 50% 46%, rgba(255, 221, 95, 0.24), rgba(255, 221, 95, 0));
  opacity: 0;
  transform: scale(0.82);
  animation: prize-aura-pop 760ms ease-out both;
  animation-delay: var(--reveal-delay);
}

.reward-note {
  position: absolute;
  right: 16rpx;
  bottom: 14rpx;
  left: 16rpx;
  z-index: 6;
  display: flex;
  height: 38rpx;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 245, 200, 0.9);
  color: #8b642c;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.rare-flash {
  position: absolute;
  top: -16%;
  bottom: -16%;
  left: -56%;
  z-index: 5;
  width: 42%;
  background: linear-gradient(100deg, transparent, rgba(255, 255, 255, 0.74), transparent);
  opacity: 0;
  transform: rotate(14deg);
  pointer-events: none;
}

.new-badge,
.duplicate-badge {
  position: absolute;
  top: -14rpx;
  left: 8rpx;
  z-index: 6;
  min-width: 60rpx;
  padding: 9rpx 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: #ff8fa5;
  box-shadow: 0 8rpx 14rpx rgba(116, 65, 42, 0.16);
  color: #fff;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.duplicate-badge {
  background: #7fb9d7;
}

.reveal-card.rarity-SR {
  background: rgba(255, 245, 181, 0.76);
}

.reveal-card.rarity-SSR {
  background: rgba(255, 220, 237, 0.8);
  box-shadow:
    0 12rpx 20rpx rgba(148, 74, 113, 0.16),
    0 0 26rpx rgba(255, 202, 226, 0.52),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.72);
}

.reveal-card.rarity-SR .prize-aura {
  background: radial-gradient(ellipse at 50% 46%, rgba(255, 212, 72, 0.46), rgba(255, 212, 72, 0));
  animation: prize-aura-pop 900ms ease-out both, rare-aura-pulse 2.6s ease-in-out 900ms infinite;
  animation-delay: var(--reveal-delay), 900ms;
}

.reveal-card.rarity-SSR .prize-aura {
  background: radial-gradient(ellipse at 50% 46%, rgba(255, 146, 204, 0.42), rgba(255, 232, 111, 0.22) 44%, rgba(255, 232, 111, 0));
  animation: prize-aura-pop 900ms ease-out both, ssr-aura-pulse 2.2s ease-in-out 900ms infinite;
  animation-delay: var(--reveal-delay), 900ms;
}

.reveal-card.rarity-SR .rare-flash,
.reveal-card.rarity-SSR .rare-flash {
  animation: rare-sweep 1050ms ease-out 360ms both;
  animation-delay: var(--reveal-delay);
}

.rare-prize {
  animation-name: rare-card-reveal;
  animation-duration: 900ms;
}

.album-btn {
  margin-top: 34rpx;
}

@keyframes chest-shake {
  0% {
    transform: translateX(0) rotate(0);
  }
  14% {
    transform: translateX(-12rpx) rotate(-4deg);
  }
  28% {
    transform: translateX(12rpx) rotate(4deg);
  }
  42% {
    transform: translateX(-10rpx) rotate(-3deg);
  }
  56% {
    transform: translateX(10rpx) rotate(3deg);
  }
  72% {
    transform: translateX(-5rpx) rotate(-1.5deg);
  }
  100% {
    transform: translateX(0) rotate(0);
  }
}

@keyframes chest-lid-open {
  0% {
    transform: translateY(0) rotate(0);
  }
  24% {
    transform: translateY(0) rotate(0);
  }
  58% {
    transform: translateY(-42rpx) rotate(-8deg);
  }
  100% {
    transform: translate(-12rpx, -108rpx) rotate(-16deg) scaleY(0.92);
  }
}

@keyframes chest-light-bloom {
  0% {
    opacity: 0;
    transform: translateX(-50%) scale(0.32);
  }
  30% {
    opacity: 0;
  }
