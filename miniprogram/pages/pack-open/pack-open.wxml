<view class="page pack-page">
  <view class="page-glow glow-a"></view>
  <view class="page-glow glow-b"></view>

  <view wx:if="{{!revealed}}" class="pack-stage {{activeTheme.packClass}} {{openingClass}}">
    <view class="top-copy">
      <view class="eyebrow">今日奖励</view>
      <view class="pack-title">{{packTitle}}</view>
      <view class="muted">{{packHint}}</view>
    </view>

    <view class="treasure-stage">
      <view class="burst"></view>
      <view class="chest-light light-core"></view>
      <view class="gold-rays">
        <view class="gold-ray ray-a"></view>
        <view class="gold-ray ray-b"></view>
        <view class="gold-ray ray-c"></view>
        <view class="gold-ray ray-d"></view>
        <view class="gold-ray ray-e"></view>
      </view>
      <view class="spark spark-a">★</view>
      <view class="spark spark-b">✦</view>
      <view class="spark spark-c">★</view>
      <view class="spark spark-d">✦</view>
      <view class="treasure-chest">
        <view class="chest-lid">
          <view class="lid-ridge"></view>
          <view class="lid-gem">★</view>
        </view>
        <view class="chest-base">
          <view class="chest-band"></view>
          <view class="chest-tag">{{packMark}}</view>
          <view class="chest-lock">★</view>
          <view class="chest-shine"></view>
        </view>
      </view>
      <view class="table-shadow"></view>
    </view>

    <view class="open-note">轻轻打开宝箱，等待金光里的惊喜</view>
    <button class="open-btn open-main-btn" disabled="{{opening}}" bindtap="beginOpen">
      <view class="btn-star">★</view>
      <text>{{openButtonText}}</text>
    </button>
  </view>

  <view wx:else class="result-stage">
    <view class="result-header">
      <view class="eyebrow">开包完成</view>
      <view class="result-title reveal-title">{{resultTitle}}</view>
      <view class="result-subtitle">{{resultSubtitle}}</view>
    </view>

    <view class="result-board">
      <view class="board-tape tape-left"></view>
      <view class="board-tape tape-right"></view>
      <view class="reward-spark spark-left">★</view>
      <view class="reward-spark spark-right">✦</view>
      <view class="card-grid">
        <view wx:for="{{revealCards}}" wx:key="id" class="reveal-card rarity-{{item.rarity}} {{item.rareClass}}" style="--reveal-delay: {{item.revealDelay}}; animation-delay: {{item.revealDelay}};" bindtap="openCard" data-id="{{item.id}}">
          <view class="prize-aura"></view>
          <view class="rare-flash"></view>
          <view class="{{item.badgeClass}}">{{item.badgeText}}</view>
          <card-face card="{{item}}" size="medium" />
          <view class="reward-note">{{item.rewardText}}</view>
        </view>
      </view>
    </view>

    <button class="open-btn album-btn" bindtap="goAlbum">
      <view class="btn-star">★</view>
      <text>放进收藏本</text>
    </button>
  </view>
</view>
