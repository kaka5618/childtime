.block {
  padding: 28rpx;
}

.block + .block {
  margin-top: 22rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.block-title.compact {
  margin-bottom: 8rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(35, 51, 43, 0.08);
  font-weight: 700;
}

.setting-btn {
  height: 64rpx;
  margin-top: 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 25rpx;
  line-height: 64rpx;
}

.setting-note {
  margin-top: 14rpx;
  color: #748078;
  font-size: 24rpx;
  line-height: 1.45;
}

.voice-options {
  margin-top: 24rpx;
}

.voice-options.disabled {
  opacity: 0.48;
}

.option-label {
  color: #526259;
  font-size: 25rpx;
  font-weight: 700;
}

.voice-type-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.voice-type {
  flex: 1;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.28);
  background: rgba(255, 250, 244, 0.78);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 58rpx;
}

.voice-type.active {
  border-color: rgba(123, 166, 140, 0.72);
  background: rgba(123, 166, 140, 0.16);
  color: #2f6b49;
  font-weight: 700;
}

.volume-label {
  margin-top: 22rpx;
}

.debug-block {
  border-color: rgba(200, 90, 84, 0.18);
}

.debug-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.debug-btn {
  height: 62rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.3);
  background: rgba(123, 166, 140, 0.1);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 62rpx;
}

.debug-btn.danger {
  border-color: rgba(200, 90, 84, 0.3);
  background: rgba(200, 90, 84, 0.08);
  color: #b84f4a;
}
