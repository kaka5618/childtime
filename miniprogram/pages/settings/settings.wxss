.block {
  padding: 28rpx;
}

.block + .block {
  margin-top: 22rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(35, 51, 43, 0.08);
  font-weight: 700;
}

.setting-btn {
  height: 64rpx;
  margin-top: 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 25rpx;
  line-height: 64rpx;
}
