.settings-page {
  position: relative;
  min-height: 100vh;
  padding: 42rpx 30rpx 58rpx;
  background:
    radial-gradient(circle at 18% 8%, rgba(255, 226, 128, 0.52), transparent 25%),
    radial-gradient(circle at 86% 18%, rgba(255, 174, 204, 0.34), transparent 27%),
    linear-gradient(180deg, #fff0bd 0%, #f8fbdf 50%, #def0d2 100%);
  color: #543820;
  font-family: "Arial Rounded MT Bold", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.settings-page view,
.settings-page text {
  font-weight: 900;
}

.block {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.68);
  border-radius: 30rpx;
  background:
    linear-gradient(90deg, rgba(126, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 252, 238, 0.94), rgba(255, 246, 218, 0.94));
  background-size: 42rpx 42rpx, 100% 100%;
  box-shadow:
    0 14rpx 28rpx rgba(103, 73, 36, 0.12),
    inset 0 0 0 6rpx rgba(255, 255, 255, 0.32);
}

.block::before {
  position: absolute;
  top: -22rpx;
  right: 34rpx;
  width: 118rpx;
  height: 42rpx;
  border-radius: 10rpx;
  background: rgba(255, 205, 152, 0.42);
  content: "";
  transform: rotate(5deg);
}

.block + .block {
  margin-top: 24rpx;
}

.block-title {
  position: relative;
  display: inline-flex;
  margin-bottom: 16rpx;
  align-items: center;
  color: #4f7d58;
  font-size: 32rpx;
  line-height: 1.18;
}

.block-title::before {
  width: 38rpx;
  height: 38rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #fff1b3;
  color: #efb22f;
  content: "★";
  font-size: 24rpx;
  line-height: 38rpx;
  text-align: center;
}

.block-title.compact {
  margin-bottom: 8rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.row {
  display: flex;
  min-height: 58rpx;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.66);
  color: #5d4934;
  font-size: 25rpx;
}

.row + .row {
  margin-top: 10rpx;
}

.setting-btn {
  box-sizing: border-box;
  display: flex;
  width: 100%;
  height: 72rpx;
  margin-top: 20rpx;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #dff3c5, #a6d982);
  box-shadow:
    0 8rpx 0 rgba(91, 131, 85, 0.46),
    0 14rpx 18rpx rgba(75, 105, 66, 0.12),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
  color: #3e6d31;
  font-size: 26rpx;
  line-height: 72rpx;
  text-align: center;
}

.setting-btn::after,
.voice-type::after,
.account-btn::after,
.account-btn.verify::after,
.backup-btn::after,
.avatar-option::after,
.grade-option::after {
  border: 0;
}

.profile-head {
  display: grid;
  grid-template-columns: 92rpx 1fr;
  gap: 18rpx;
  align-items: center;
}

.profile-avatar {
  display: flex;
  width: 88rpx;
  height: 88rpx;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: #fff4cf;
  box-shadow: 0 8rpx 14rpx rgba(112, 82, 44, 0.14);
  font-size: 46rpx;
  line-height: 1;
}

.profile-copy {
  min-width: 0;
}

.profile-section {
  margin-top: 24rpx;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.avatar-option {
  box-sizing: border-box;
  display: flex;
  min-width: 0;
  height: 86rpx;
  margin: 0;
  padding: 0 18rpx;
  border: 3rpx solid rgba(123, 166, 140, 0.2);
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #5d4934;
  overflow: hidden;
}

.avatar-option.active,
.grade-option.active {
  border-color: rgba(123, 166, 140, 0.66);
  background: linear-gradient(180deg, #dff4c3, #b9e596);
  color: #2f6b49;
  box-shadow: 0 8rpx 12rpx rgba(75, 105, 66, 0.12);
}

.avatar-emoji {
  flex: none;
  font-size: 34rpx;
  line-height: 1;
}

.avatar-label {
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.grade-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.grade-option {
  box-sizing: border-box;
  display: flex;
  min-width: 0;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border: 3rpx solid rgba(123, 166, 140, 0.2);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  align-items: center;
  justify-content: center;
  color: #4e6356;
  font-size: 23rpx;
  line-height: 64rpx;
  text-align: center;
  white-space: nowrap;
}

.setting-note {
  margin-top: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 244, 205, 0.72);
  color: #8a6a42;
  font-size: 23rpx;
  line-height: 1.45;
}

.muted {
  color: #6f7d70;
  font-size: 24rpx;
  line-height: 1.48;
}

.voice-options {
  margin-top: 24rpx;
}

.voice-options.disabled {
  opacity: 0.48;
}

.option-label {
  color: #4f7d58;
  font-size: 25rpx;
}

.voice-type-row {
  display: flex;
  gap: 14rpx;
  margin-top: 14rpx;
}

.voice-type {
  box-sizing: border-box;
  display: flex;
  min-width: 0;
  flex: 1;
  height: 64rpx;
  margin: 0;
  padding: 0;
  border: 3rpx solid rgba(123, 166, 140, 0.2);
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.82);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 64rpx;
  text-align: center;
  white-space: nowrap;
}

.voice-type.active {
  border-color: rgba(123, 166, 140, 0.6);
  background: linear-gradient(180deg, #dff4c3, #b9e596);
  color: #2f6b49;
}

.volume-label {
  margin-top: 24rpx;
}

.account-block {
  border-color: rgba(112, 164, 142, 0.3);
}

.account-head {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 18rpx;
  align-items: start;
}

.account-badge {
  min-width: 116rpx;
  padding: 10rpx 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 999rpx;
  background: #eef8e4;
  color: #4f7d58;
  font-size: 21rpx;
  line-height: 1;
  text-align: center;
}

.account-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 20rpx;
}

.account-btn {
  box-sizing: border-box;
  display: flex;
  min-width: 0;
  height: 70rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: inset 0 0 0 3rpx rgba(123, 166, 140, 0.18);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 70rpx;
  text-align: center;
  white-space: nowrap;
}

.account-btn.disabled {
  opacity: 0.68;
  pointer-events: none;
}

.account-wide {
  grid-column: 1 / -1;
}

.account-btn.primary {
  background: linear-gradient(180deg, #dff4c3, #b9e596);
  box-shadow:
    0 7rpx 0 rgba(91, 131, 85, 0.42),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
  color: #2f6b49;
}

.account-btn.sync {
  background: linear-gradient(180deg, #fff0bd, #ffd372);
  box-shadow:
    0 7rpx 0 rgba(177, 124, 40, 0.34),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.55);
  color: #7a5620;
}

.account-btn.restore {
  background: linear-gradient(180deg, #dff4ff, #a9dcec);
  box-shadow:
    0 7rpx 0 rgba(72, 132, 155, 0.3),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.55);
  color: #376271;
}

.account-btn.verify {
  background: linear-gradient(180deg, #fff7dc, #f7d395);
  box-shadow:
    0 7rpx 0 rgba(165, 115, 48, 0.28),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.58);
  color: #7a5620;
}

.setting-note.strong {
  color: #3f7352;
  font-weight: 700;
}

.backup-block {
  border-color: rgba(123, 166, 140, 0.28);
}

.backup-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.backup-btn {
  box-sizing: border-box;
  display: flex;
  min-width: 0;
  height: 66rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: inset 0 0 0 3rpx rgba(123, 166, 140, 0.18);
  color: #4e6356;
  font-size: 23rpx;
  line-height: 66rpx;
  text-align: center;
  white-space: nowrap;
}

.backup-btn.primary {
  background: linear-gradient(180deg, #dff4c3, #b9e596);
  box-shadow:
    0 7rpx 0 rgba(91, 131, 85, 0.42),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.52);
  color: #2f6b49;
}

.backup-btn.danger {
  background: rgba(200, 90, 84, 0.12);
  color: #b84f4a;
}

.backup-wide {
  grid-column: 1 / -1;
}

.name-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  background: rgba(48, 38, 28, 0.42);
}

.name-modal {
  position: relative;
  box-sizing: border-box;
  width: 560rpx;
  max-width: 100%;
  padding: 56rpx 42rpx 42rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 36rpx;
  background:
    linear-gradient(90deg, rgba(126, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 252, 238, 0.98), rgba(255, 244, 213, 0.98));
  background-size: 42rpx 42rpx, 100% 100%;
  box-shadow:
    0 24rpx 46rpx rgba(52, 38, 24, 0.26),
    inset 0 0 0 6rpx rgba(255, 255, 255, 0.34);
  text-align: center;
}

.name-modal-star {
  position: absolute;
  top: -34rpx;
  left: 50%;
  width: 68rpx;
  height: 68rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  background: #fff1ad;
  box-shadow: 0 9rpx 16rpx rgba(116, 79, 32, 0.16);
  color: #efb62b;
  font-size: 40rpx;
  line-height: 68rpx;
  transform: translateX(-50%);
}

.name-modal-title {
  color: #5a3a20;
  font-size: 40rpx;
  line-height: 1.15;
  text-shadow: 0 3rpx 0 rgba(255, 246, 218, 0.9);
}

.name-modal-input {
  box-sizing: border-box;
  width: 100%;
  height: 84rpx;
  margin-top: 34rpx;
  padding: 0 26rpx;
  border: 3rpx solid rgba(123, 166, 140, 0.3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 5rpx 0 rgba(255, 244, 207, 0.64);
  color: #4a2a13;
  font-size: 30rpx;
  line-height: 84rpx;
  text-align: center;
}

.name-modal-actions {
  display: flex;
  width: 100%;
  margin-top: 34rpx;
  gap: 18rpx;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.name-modal-btn {
  box-sizing: border-box;
  display: flex;
  flex: 1 1 0;
  min-width: 0;
  max-width: 240rpx;
  height: 78rpx;
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 999rpx;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #ffe27a, #f6b846);
  box-shadow:
    0 9rpx 0 #cf8930,
    0 15rpx 22rpx rgba(125, 76, 29, 0.18),
    inset 0 5rpx 0 rgba(255, 250, 215, 0.82);
  color: #744818;
  font-size: 28rpx;
  line-height: 78rpx;
  text-align: center;
}

.name-modal-btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  box-shadow:
    0 9rpx 0 rgba(157, 180, 154, 0.56),
    inset 0 0 0 3rpx rgba(123, 166, 140, 0.2);
  color: #557865;
}

.name-modal-btn::after {
  border: 0;
}
