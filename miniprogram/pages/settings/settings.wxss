.block {
  padding: 28rpx;
}

.block + .block {
  margin-top: 22rpx;
}

.block-title {
  margin-bottom: 18rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.block-title.compact {
  margin-bottom: 8rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(35, 51, 43, 0.08);
  font-weight: 700;
}

.setting-btn {
  height: 64rpx;
  margin-top: 18rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 25rpx;
  line-height: 64rpx;
}

.setting-note {
  margin-top: 14rpx;
  color: #748078;
  font-size: 24rpx;
  line-height: 1.45;
}

.voice-options {
  margin-top: 24rpx;
}

.voice-options.disabled {
  opacity: 0.48;
}

.option-label {
  color: #526259;
  font-size: 25rpx;
  font-weight: 700;
}

.voice-type-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.voice-type {
  flex: 1;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.28);
  background: rgba(255, 250, 244, 0.78);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 58rpx;
}

.voice-type.active {
  border-color: rgba(123, 166, 140, 0.72);
  background: rgba(123, 166, 140, 0.16);
  color: #2f6b49;
  font-weight: 700;
}

.volume-label {
  margin-top: 22rpx;
}

.debug-block {
  border-color: rgba(200, 90, 84, 0.18);
}

.debug-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.debug-btn {
  height: 62rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(123, 166, 140, 0.3);
  background: rgba(123, 166, 140, 0.1);
  color: #4e6356;
  font-size: 24rpx;
  line-height: 62rpx;
}

.debug-btn.danger {
  border-color: rgba(200, 90, 84, 0.3);
  background: rgba(200, 90, 84, 0.08);
  color: #b84f4a;
}

.name-modal-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  background: rgba(48, 38, 28, 0.42);
}

.name-modal {
  position: relative;
  width: 560rpx;
  padding: 56rpx 42rpx 42rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 36rpx;
  background:
    linear-gradient(90deg, rgba(126, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(255, 252, 238, 0.98), rgba(255, 244, 213, 0.98));
  background-size: 42rpx 42rpx, 100% 100%;
  box-shadow:
    0 24rpx 46rpx rgba(52, 38, 24, 0.26),
    inset 0 0 0 6rpx rgba(255, 255, 255, 0.34);
  text-align: center;
}

.name-modal-star {
  position: absolute;
  top: -34rpx;
  left: 50%;
  width: 68rpx;
  height: 68rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 50%;
  background: #fff1ad;
  box-shadow: 0 9rpx 16rpx rgba(116, 79, 32, 0.16);
  color: #efb62b;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 68rpx;
  transform: translateX(-50%);
}

.name-modal-title {
  color: #5a3a20;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.15;
  text-shadow: 0 3rpx 0 rgba(255, 246, 218, 0.9);
}

.name-modal-input {
  height: 84rpx;
  margin-top: 34rpx;
  padding: 0 26rpx;
  border: 3rpx solid rgba(123, 166, 140, 0.3);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: inset 0 5rpx 0 rgba(255, 244, 207, 0.64);
  color: #4a2a13;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 84rpx;
  text-align: center;
}

.name-modal-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
  margin-top: 34rpx;
}

.name-modal-btn {
  height: 78rpx;
  margin: 0;
  border: 0;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #ffe27a, #f6b846);
  box-shadow:
    0 9rpx 0 #cf8930,
    0 15rpx 22rpx rgba(125, 76, 29, 0.18),
    inset 0 5rpx 0 rgba(255, 250, 215, 0.82);
  color: #744818;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 78rpx;
}

.name-modal-btn.secondary {
  background: rgba(255, 255, 255, 0.9);
  box-shadow:
    0 9rpx 0 rgba(157, 180, 154, 0.56),
    inset 0 0 0 3rpx rgba(123, 166, 140, 0.2);
  color: #557865;
}

.name-modal-btn::after {
  border: 0;
}
