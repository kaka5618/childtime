<view class="page settings-page">
  <view class="panel block profile-block">
    <view class="profile-head">
      <view class="profile-avatar">{{avatarEmoji}}</view>
      <view class="profile-copy">
        <view class="block-title compact">孩子档案</view>
        <view class="muted">{{childName}} · {{gradeLabel}} · 目标 {{dailyTargetMinutes}} 分钟</view>
      </view>
    </view>
    <view class="setting-btn" bindtap="editChildName">修改名字</view>

    <view class="profile-section">
      <view class="option-label">头像贴纸</view>
      <view class="avatar-grid">
        <view wx:for="{{avatarOptions}}" wx:key="key" class="avatar-option {{item.activeClass}}" data-key="{{item.key}}" data-emoji="{{item.emoji}}" bindtap="selectAvatar">
          <view class="avatar-emoji">{{item.emoji}}</view>
          <view class="avatar-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="profile-section">
      <view class="option-label">年龄段</view>
      <view class="grade-grid">
        <view wx:for="{{gradeOptions}}" wx:key="key" class="grade-option {{item.activeClass}}" data-key="{{item.key}}" data-label="{{item.label}}" bindtap="selectGrade">{{item.label}}</view>
      </view>
    </view>

    <view class="profile-section">
      <view class="option-label">每日目标 {{dailyTargetMinutes}} 分钟</view>
      <slider min="15" max="120" step="5" value="{{dailyTargetMinutes}}" activeColor="#7BA68C" block-color="#7BA68C" bindchange="changeDailyTarget" />
    </view>
  </view>

  <view class="panel block">
    <view class="block-title">当前收集</view>
    <view class="muted">{{activeThemeName}}</view>
    <view wx:if="{{nextSwitchDate}}" class="setting-note">每 15 天可更换一次收集主题。下次可更换：{{nextSwitchDate}}</view>
    <view class="setting-btn" bindtap="goThemeSelect">选择卡包</view>
  </view>

  <view class="panel block">
    <view class="setting-row">
      <view>
        <view class="block-title compact">语音提醒</view>
        <view class="muted">任务开始、完成和全部完成时使用。</view>
      </view>
      <switch checked="{{voiceEnabled}}" color="#7BA68C" bindchange="toggleVoice" />
    </view>

    <view class="voice-options {{voiceOptionsClass}}">
      <view class="option-label">音色</view>
      <view class="voice-type-row">
        <view wx:for="{{voiceTypes}}" wx:key="key" class="voice-type {{item.activeClass}}" data-type="{{item.key}}" bindtap="changeVoiceType">{{item.label}}</view>
      </view>

      <view class="option-label volume-label">音量 {{volume}}%</view>
      <slider min="0" max="100" step="5" value="{{volume}}" activeColor="#7BA68C" block-color="#7BA68C" bindchange="changeVolume" />
    </view>
  </view>

  <view class="panel block account-block">
    <view class="account-head">
      <view>
        <view class="block-title compact">微信账号</view>
        <view class="muted">{{accountSummary}}</view>
      </view>
      <view class="account-badge">{{accountBadgeText}}</view>
    </view>
    <view class="account-actions">
      <view class="account-btn primary" bindtap="connectWechatAccount">微信登录</view>
      <view class="account-btn sync {{syncBusyClass}}" bindtap="syncCloudData">{{syncButtonText}}</view>
      <view class="account-btn verify {{syncBusyClass}}" bindtap="verifyCloudData">{{verifyCloudButtonText}}</view>
      <view class="account-btn restore {{syncBusyClass}}" bindtap="restoreCloudData">{{restoreCloudButtonText}}</view>
      <view class="account-btn account-wide" bindtap="disconnectWechatAccount">解除状态</view>
    </view>
    <view class="setting-note strong">{{syncSummary}}</view>
    <view class="setting-note">使用微信身份手动同步孩子档案、任务和收藏；需要时可点“同步云端”保存最新数据。</view>
  </view>

  <view class="panel block backup-block">
    <view class="block-title">本地备份</view>
    <view class="muted">{{backupSummary}}</view>
    <view class="backup-actions">
      <view class="backup-btn primary" bindtap="createLocalBackup">保存备份</view>
      <view class="backup-btn" bindtap="restoreLocalBackup">恢复备份</view>
      <view class="backup-btn danger backup-wide" bindtap="clearLocalBackup">删除备份</view>
    </view>
    <view class="setting-note">备份只保存在当前设备；从云端恢复前会自动保存一份本机备份，方便误操作后回退。</view>
  </view>

  <view class="panel block privacy-block">
    <view class="block-title">隐私与数据</view>
    <view class="muted">孩子名字、头像贴纸、学习任务、收藏进度和开包记录用于展示计划、同步进度和恢复数据。</view>
    <view class="setting-note">微信登录只用于识别同一个微信账号下的数据；不使用手机号、定位或通讯录。</view>
    <view class="setting-btn privacy-btn" bindtap="openPrivacyGuide">查看隐私指引</view>
  </view>

  <view class="panel block">
    <view class="block-title">抽卡概率</view>
    <view class="row"><text>传说 SSR</text><text>3.0%</text></view>
    <view class="row"><text>稀有 SR</text><text>12.0%</text></view>
    <view class="row"><text>精良 R</text><text>30.0%</text></view>
    <view class="row"><text>普通 N</text><text>55.0%</text></view>
  </view>

  <view class="panel block">
    <view class="block-title">保底规则</view>
    <view class="muted">每个卡包随机包含 1-5 张卡。当前主题未集齐时，每日基础包至少包含 1 张未拥有卡，帮助孩子持续推进收藏进度。</view>
  </view>

  <view class="panel block">
    <view class="block-title">合成规则</view>
    <view class="muted">同一张卡拥有 4 张或以上时，可以在收藏本中消耗 3 张重复卡合成 1 个额外卡包，并至少保留 1 张收藏卡。合成包不占用每日基础开包机会。</view>
  </view>

  <view wx:if="{{nameEditorVisible}}" class="name-modal-mask">
    <view class="name-modal">
      <view class="name-modal-star">★</view>
      <view class="name-modal-title">修改名字</view>
      <input class="name-modal-input" maxlength="8" value="{{nameDraft}}" placeholder="例如：小星星" bindinput="onNameDraftInput" focus />
      <view class="name-modal-actions">
        <view class="name-modal-btn secondary" bindtap="closeNameEditor">取消</view>
        <view class="name-modal-btn" bindtap="saveNameEditor">保存</view>
      </view>
    </view>
  </view>
</view>
