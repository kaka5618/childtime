<view class="page settings-page">
  <view class="panel block profile-block">
    <view class="profile-head">
      <view class="profile-avatar">{{avatarEmoji}}</view>
      <view class="profile-copy">
        <view class="block-title compact">孩子档案</view>
        <view class="muted">{{childName}} · {{gradeLabel}} · 目标 {{dailyTargetMinutes}} 分钟</view>
      </view>
    </view>
    <button class="setting-btn" bindtap="editChildName">修改名字</button>

    <view class="profile-section">
      <view class="option-label">头像贴纸</view>
      <view class="avatar-grid">
        <button wx:for="{{avatarOptions}}" wx:key="key" class="avatar-option {{item.activeClass}}" data-key="{{item.key}}" data-emoji="{{item.emoji}}" bindtap="selectAvatar">
          <view class="avatar-emoji">{{item.emoji}}</view>
          <view class="avatar-label">{{item.label}}</view>
        </button>
      </view>
    </view>

    <view class="profile-section">
      <view class="option-label">年龄段</view>
      <view class="grade-grid">
        <button wx:for="{{gradeOptions}}" wx:key="key" class="grade-option {{item.activeClass}}" data-key="{{item.key}}" data-label="{{item.label}}" bindtap="selectGrade">{{item.label}}</button>
      </view>
    </view>

    <view class="profile-section">
      <view class="option-label">每日目标 {{dailyTargetMinutes}} 分钟</view>
      <slider min="15" max="120" step="5" value="{{dailyTargetMinutes}}" activeColor="#7BA68C" block-color="#7BA68C" bindchange="changeDailyTarget" />
    </view>
  </view>

  <view class="panel block">
    <view class="block-title">当前收集</view>
    <view class="muted">{{activeThemeName}}</view>
    <view wx:if="{{nextSwitchDate}}" class="setting-note">每 15 天可更换一次收集主题。下次可更换：{{nextSwitchDate}}</view>
    <button class="setting-btn" bindtap="goThemeSelect">选择卡包</button>
  </view>

  <view class="panel block">
    <view class="setting-row">
      <view>
        <view class="block-title compact">语音提醒</view>
        <view class="muted">任务开始、完成和全部完成时使用。</view>
      </view>
      <switch checked="{{voiceEnabled}}" color="#7BA68C" bindchange="toggleVoice" />
    </view>

    <view class="voice-options {{voiceOptionsClass}}">
      <view class="option-label">音色</view>
      <view class="voice-type-row">
        <button wx:for="{{voiceTypes}}" wx:key="key" class="voice-type {{item.activeClass}}" data-type="{{item.key}}" bindtap="changeVoiceType">{{item.label}}</button>
      </view>

      <view class="option-label volume-label">音量 {{volume}}%</view>
      <slider min="0" max="100" step="5" value="{{volume}}" activeColor="#7BA68C" block-color="#7BA68C" bindchange="changeVolume" />
    </view>
  </view>

  <view class="panel block backup-block">
    <view class="block-title">本地备份</view>
    <view class="muted">{{backupSummary}}</view>
    <view class="backup-actions">
      <button class="backup-btn primary" bindtap="createLocalBackup">保存备份</button>
      <button class="backup-btn" bindtap="restoreLocalBackup">恢复备份</button>
      <button class="backup-btn danger" bindtap="clearLocalBackup">删除备份</button>
    </view>
    <view class="setting-note">备份只保存在当前设备，后续接入微信登录后可迁移到云端。</view>
  </view>

  <view class="panel block">
    <view class="block-title">抽卡概率</view>
    <view class="row"><text>传说 SSR</text><text>3.0%</text></view>
    <view class="row"><text>稀有 SR</text><text>12.0%</text></view>
    <view class="row"><text>精良 R</text><text>30.0%</text></view>
    <view class="row"><text>普通 N</text><text>55.0%</text></view>
  </view>

  <view class="panel block">
    <view class="block-title">保底规则</view>
    <view class="muted">每个卡包随机包含 1-5 张卡。当前主题未集齐时，每日基础包至少包含 1 张未拥有卡。MVP 版本先使用本地存储模拟收藏进度。</view>
  </view>

  <view class="panel block">
    <view class="block-title" bindlongpress="revealDebugTools">合成规则</view>
    <view class="muted">同一张卡拥有 4 张或以上时，可以在收藏本中消耗 3 张重复卡合成 1 个额外卡包，并至少保留 1 张收藏卡。合成包不占用每日基础开包机会。</view>
  </view>

  <view wx:if="{{debugVisible}}" class="panel block debug-block">
    <view class="block-title">调试工具</view>
    <view class="muted">MVP 本地验收使用，上线前隐藏。</view>
    <view class="debug-grid">
      <button class="debug-btn" bindtap="addDebugTasks">加测试任务</button>
      <button class="debug-btn" bindtap="completeDebugTasks">完成任务</button>
      <button class="debug-btn" bindtap="resetDebugPack">重置开包</button>
      <button class="debug-btn" bindtap="addDebugDuplicates">加重复卡</button>
      <button class="debug-btn danger" bindtap="clearDebugTasks">清空任务</button>
      <button class="debug-btn danger" bindtap="clearDebugCollection">清空收藏</button>
    </view>
  </view>

  <view wx:if="{{nameEditorVisible}}" class="name-modal-mask">
    <view class="name-modal">
      <view class="name-modal-star">★</view>
      <view class="name-modal-title">修改名字</view>
      <input class="name-modal-input" maxlength="8" value="{{nameDraft}}" placeholder="例如：小星星" bindinput="onNameDraftInput" focus />
      <view class="name-modal-actions">
        <button class="name-modal-btn secondary" bindtap="closeNameEditor">取消</button>
        <button class="name-modal-btn" bindtap="saveNameEditor">保存</button>
      </view>
    </view>
  </view>
</view>
