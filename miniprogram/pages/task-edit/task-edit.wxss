.form {
  padding: 32rpx;
}

.field + .field {
  margin-top: 34rpx;
}

.label {
  margin-bottom: 14rpx;
  color: #526259;
  font-size: 26rpx;
  font-weight: 700;
}

.input {
  height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(35, 51, 43, 0.14);
  border-radius: 8px;
  background: #fff;
}

.minutes-row {
  display: grid;
  grid-template-columns: 1fr 150rpx;
  align-items: center;
  gap: 16rpx;
}

.minutes {
  text-align: right;
  font-weight: 700;
}

.save-btn {
  margin-top: 32rpx;
}

.delete-btn {
  margin-top: 18rpx;
  border: 1rpx solid rgba(200, 90, 84, 0.36);
  background: rgba(200, 90, 84, 0.08);
  color: #c85a54;
}
