<view class="page focus-page" wx:if="{{task}}">
  <image class="focus-bg-img" src="{{focusBgUrl}}" mode="aspectFill" />

  <view class="focus-hero">
    <view class="back-btn" bindtap="goHome">‹</view>
    <view class="hero-title">星星学习计划</view>
    <view class="hero-subtitle">认真学习，星星会为你发光</view>
  </view>

  <view class="focus-card {{completedCardClass}}">
    <view class="notebook-ring ring-one"></view>
    <view class="notebook-ring ring-two"></view>
    <view class="notebook-ring ring-three"></view>
    <view class="bookmark-star">★</view>
    <view class="focus-label">正在专注</view>
    <view class="focus-title">{{task.name}}</view>
    <view class="timer-ring">
      <view class="timer-ring-inner">
        <view class="timer-icon">◷</view>
        <view class="timer">{{timeText}}</view>
        <view class="timer-unit">分钟 · 秒</view>
      </view>
    </view>
    <view class="focus-hint">
      <view class="hint-dot"></view>
      <text>{{timerHint}}</text>
    </view>

    <button wx:if="{{!rewardVisible}}" class="complete-btn" bindlongpress="completeTask">
      <view class="tap-icon">☝</view>
      <text>{{completeButtonText}}</text>
    </button>

    <view wx:if="{{rewardVisible}}" class="reward-panel">
      <view class="reward-burst">
        <view class="reward-star star-a">★</view>
        <view class="reward-star star-b">★</view>
        <view class="reward-star star-c">★</view>
        <view class="reward-core">✓</view>
      </view>
      <view class="reward-title">{{rewardTitle}}</view>
      <view class="reward-text">{{rewardText}}</view>
      <button wx:if="{{canOpenPack}}" class="complete-btn reward-action" bindtap="goPack">去开包</button>
      <button wx:else class="complete-btn reward-action secondary-action" bindtap="goHome">返回任务</button>
    </view>
  </view>
</view>
