<view class="page focus-page" wx:if="{{task}}">
  <view class="focus-card panel">
    <view class="focus-label">正在专注</view>
    <view class="focus-title">{{task.name}}</view>
    <view class="timer">{{timeText}}</view>
    <view class="muted">倒计时结束后也可以继续完成。</view>
  </view>

  <button class="complete-btn primary-btn" bindlongpress="completeTask">长按完成</button>
</view>
