.focus-page {
  position: relative;
  display: flex;
  min-height: 100vh;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding: 52rpx 28rpx 120rpx;
  background:
    linear-gradient(180deg, rgba(255, 244, 218, 0.96), rgba(239, 248, 239, 0.96)),
    #faf6f0;
  text-align: center;
}

.desk-scene {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.lamp-glow {
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 222, 141, 0.58), rgba(255, 222, 141, 0));
}

.pencil {
  position: absolute;
  border-radius: 999rpx;
  opacity: 0.8;
  transform: rotate(-18deg);
}

.pencil::before {
  position: absolute;
  top: 0;
  left: -18rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 999rpx 0 0 999rpx;
  background: #f5c26b;
  content: "";
}

.pencil-a {
  right: -48rpx;
  bottom: 180rpx;
  width: 230rpx;
  height: 28rpx;
  background: #7ba68c;
}

.pencil-b {
  left: -68rpx;
  bottom: 88rpx;
  width: 250rpx;
  height: 24rpx;
  background: #f29faa;
  transform: rotate(18deg);
}

.bookmark-star {
  position: absolute;
  top: 112rpx;
  left: 48rpx;
  color: #f5c26b;
  font-size: 44rpx;
  text-shadow: 0 8rpx 18rpx rgba(245, 194, 107, 0.28);
  transform: rotate(-10deg);
}

.focus-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  padding: 64rpx 34rpx 52rpx;
  border: 2rpx solid rgba(157, 118, 76, 0.12);
  border-radius: 18rpx;
  background:
    linear-gradient(90deg, rgba(123, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, #fffdf7 0%, #fff8e8 100%);
  background-size: 42rpx 42rpx, 100% 100%;
  box-shadow: 0 22rpx 46rpx rgba(99, 79, 54, 0.13);
}

.focus-card::before {
  position: absolute;
  top: 0;
  left: 54rpx;
  width: 4rpx;
  height: 100%;
  background: rgba(242, 159, 170, 0.18);
  content: "";
}

.paper-clip {
  position: absolute;
  top: 20rpx;
  right: 42rpx;
  width: 58rpx;
  height: 82rpx;
  border: 6rpx solid rgba(123, 166, 140, 0.54);
  border-bottom-color: transparent;
  border-radius: 999rpx 999rpx 18rpx 18rpx;
  transform: rotate(12deg);
}

.completed-card {
  border-color: rgba(123, 166, 140, 0.3);
  background:
    linear-gradient(90deg, rgba(123, 166, 140, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, #fffdf7 0%, #eef9f0 100%);
}

.focus-label {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 24rpx;
  font-weight: 800;
}

.focus-title {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.timer-ring {
  display: flex;
  width: 312rpx;
  height: 312rpx;
  margin: 46rpx auto 26rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background:
    conic-gradient(#7ba68c 0deg, #f5c26b 140deg, #f8e1a8 140deg, #f8e1a8 360deg);
  box-shadow: inset 0 0 0 14rpx rgba(255, 255, 255, 0.72), 0 16rpx 32rpx rgba(123, 166, 140, 0.18);
}

.timer-ring-inner {
  display: flex;
  width: 244rpx;
  height: 244rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fffdf7;
}

.timer {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 70rpx;
  font-weight: 800;
  color: #2f4639;
  letter-spacing: 0;
}

.focus-hint {
  color: #6d7d73;
  font-size: 26rpx;
  line-height: 1.5;
}

.complete-btn {
  position: relative;
  z-index: 1;
  margin-top: 48rpx;
  height: 88rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 88rpx;
  box-shadow: 0 12rpx 24rpx rgba(123, 166, 140, 0.2);
}

.reward-panel {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  border: 2rpx solid rgba(123, 166, 140, 0.14);
  border-radius: 18rpx;
  background: rgba(255, 253, 247, 0.94);
  padding: 38rpx 30rpx 34rpx;
  box-shadow: 0 18rpx 38rpx rgba(99, 79, 54, 0.1);
  animation: reward-in 260ms ease-out both;
}

.reward-burst {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  margin: 0 auto;
}

.reward-core {
  position: absolute;
  top: 28rpx;
  left: 28rpx;
  width: 94rpx;
  height: 94rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f8d783, #7ba68c);
  box-shadow: 0 14rpx 30rpx rgba(123, 166, 140, 0.28);
  color: #fff;
  font-size: 56rpx;
  font-weight: 800;
  line-height: 94rpx;
}

.reward-star {
  position: absolute;
  color: #f5c26b;
  font-size: 34rpx;
  line-height: 1;
  text-shadow: 0 5rpx 12rpx rgba(245, 194, 107, 0.28);
}

.star-a {
  top: 6rpx;
  left: 28rpx;
}

.star-b {
  top: 30rpx;
  right: 12rpx;
  color: #7ba68c;
}

.star-c {
  bottom: 14rpx;
  left: 12rpx;
  color: #f29faa;
}

.reward-title {
  margin-top: 12rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.reward-text {
  margin-top: 12rpx;
  color: #748078;
  font-size: 26rpx;
  line-height: 1.5;
}

@keyframes reward-in {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.98);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
