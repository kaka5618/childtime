<view class="page theme-page {{pendingTheme ? 'has-confirm' : ''}}">
  <view class="theme-head">
    <view class="eyebrow">收集主题</view>
    <view class="title">选择你的卡包</view>
  </view>

  <view class="theme-list">
    <view wx:for="{{themes}}" wx:key="id" class="theme-card {{item.coverClass}} {{item.status === 'active' ? '' : 'preview'}} {{pendingId === item.id ? 'selected' : ''}}" bindtap="selectTheme" data-id="{{item.id}}" data-status="{{item.status}}" data-name="{{item.name}}">
      <view class="cover-stage">
        <view wx:if="{{item.hasPreviewCards}}" class="bubble-stack">
          <view wx:for="{{item.previewCards}}" wx:for-item="card" wx:for-index="cardIndex" wx:key="id" class="preview-card card-{{cardIndex}}">
            <card-face card="{{card}}" size="small" />
          </view>
        </view>
        <view wx:else class="cover-symbol">
          <view class="cover-orbit orbit-a"></view>
          <view class="cover-orbit orbit-b"></view>
          <view class="cover-gem"></view>
          <view class="symbol-main">{{item.shortName}}</view>
          <view class="symbol-line"></view>
        </view>
        <view class="cover-gloss"></view>
        <view class="theme-status">{{item.status === 'active' ? (selectedId === item.id ? '当前收集' : '可选择') : '预览'}}</view>
      </view>
      <view class="theme-main">
        <view class="theme-name">{{item.name}}</view>
        <view class="theme-desc">{{item.description}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{pendingTheme}}" class="confirm-bar">
    <view class="confirm-copy">
      <view class="confirm-label">{{selectedId === pendingId ? '当前收集' : '准备收集'}}</view>
      <view class="confirm-name">{{pendingTheme.name}}</view>
    </view>
    <button class="confirm-btn" bindtap="confirmTheme">{{selectedId === pendingId ? '继续收集' : '开始收集'}}</button>
  </view>
</view>
