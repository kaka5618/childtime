.theme-head {
  margin-bottom: 28rpx;
}

.has-confirm {
  padding-bottom: 150rpx;
}

.eyebrow {
  color: #7ba68c;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.theme-list {
  display: grid;
  gap: 24rpx;
}

.theme-card {
  position: relative;
  overflow: hidden;
  border: 1rpx solid rgba(35, 51, 43, 0.08);
  border-radius: 8px;
  background: #fffaf4;
  box-shadow: 0 12rpx 28rpx rgba(35, 51, 43, 0.08);
}

.cover-stage {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}

.bubble-cover .cover-stage {
  background:
    radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.86) 0 8rpx, transparent 9rpx),
    radial-gradient(circle at 78% 28%, rgba(255, 255, 255, 0.72) 0 7rpx, transparent 8rpx),
    linear-gradient(135deg, #c7f2e4, #9eddf5 48%, #ffd2e7);
}

.dino-cover .cover-stage {
  background:
    radial-gradient(circle at 18% 78%, rgba(255, 236, 182, 0.42) 0 48rpx, transparent 50rpx),
    linear-gradient(135deg, #e4c487, #84683f 58%, #f2ddab);
}

.mecha-cover .cover-stage {
  background:
    linear-gradient(90deg, rgba(255, 255, 255, 0.18) 0 2rpx, transparent 2rpx 40rpx),
    linear-gradient(135deg, #e6eef8, #426f9f 55%, #f2a35f);
}

.garden-cover .cover-stage {
  background:
    radial-gradient(circle at 20% 26%, rgba(255, 255, 255, 0.42) 0 34rpx, transparent 36rpx),
    radial-gradient(circle at 74% 72%, rgba(255, 255, 255, 0.36) 0 44rpx, transparent 46rpx),
    linear-gradient(135deg, #ffd7e6, #d17499 52%, #bce5af);
}

.cover-gloss {
  position: absolute;
  top: 0;
  bottom: 0;
  left: -12%;
  width: 42%;
  background: linear-gradient(110deg, transparent, rgba(255, 255, 255, 0.36), transparent);
  transform: skewX(-14deg);
}

.bubble-stack {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
}

.preview-card {
  position: absolute;
  bottom: -86rpx;
  width: 190rpx;
  border-radius: 14rpx;
  box-shadow: 0 18rpx 34rpx rgba(35, 51, 43, 0.22);
}

.card-0 {
  left: 64rpx;
  transform: rotate(-11deg) scale(0.96);
}

.card-1 {
  left: 250rpx;
  bottom: -58rpx;
  z-index: 2;
  transform: scale(1.08);
}

.card-2 {
  right: 64rpx;
  transform: rotate(11deg) scale(0.96);
}

.cover-symbol {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  bottom: 28rpx;
  left: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.54);
  border-radius: 8px;
  color: rgba(255, 255, 255, 0.92);
}

.cover-orbit {
  position: absolute;
  border: 3rpx solid rgba(255, 255, 255, 0.46);
  border-radius: 50%;
}

.orbit-a {
  width: 260rpx;
  height: 110rpx;
  transform: rotate(-18deg);
}

.orbit-b {
  width: 220rpx;
  height: 220rpx;
  opacity: 0.72;
}

.cover-gem {
  position: absolute;
  top: 56rpx;
  right: 92rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.68);
  transform: rotate(45deg);
}

.symbol-main {
  position: relative;
  z-index: 2;
  font-size: 60rpx;
  font-weight: 900;
}

.symbol-line {
  position: relative;
  z-index: 2;
  width: 112rpx;
  height: 6rpx;
  margin-top: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
}

.theme-main {
  padding: 24rpx 26rpx;
}

.theme-name {
  font-size: 34rpx;
  font-weight: 800;
}

.theme-desc {
  margin-top: 10rpx;
  color: #748078;
  font-size: 25rpx;
  line-height: 1.45;
}

.theme-status {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 3;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 244, 0.88);
  color: #3b2a12;
  font-size: 22rpx;
  font-weight: 700;
}

.selected {
  border-color: rgba(123, 166, 140, 0.86);
  box-shadow: 0 16rpx 34rpx rgba(123, 166, 140, 0.28);
  transform: translateY(-2rpx);
}

.preview {
  opacity: 0.78;
}

.confirm-bar {
  position: fixed;
  right: 24rpx;
  bottom: 28rpx;
  left: 24rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 18rpx 18rpx 24rpx;
  border: 1rpx solid rgba(123, 166, 140, 0.28);
  border-radius: 8px;
  background: rgba(255, 250, 244, 0.96);
  box-shadow: 0 16rpx 36rpx rgba(35, 51, 43, 0.16);
}

.confirm-copy {
  text-align: left;
}

.confirm-label {
  color: #7ba68c;
  font-size: 22rpx;
  font-weight: 700;
}

.confirm-name {
  margin-top: 4rpx;
  color: #23332b;
  font-size: 32rpx;
  font-weight: 800;
}

.confirm-btn {
  width: 188rpx;
  height: 72rpx;
  margin: 0;
  padding: 0;
  border-radius: 8px;
  background: #7ba68c;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 72rpx;
}
