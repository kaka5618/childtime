.album-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.eyebrow {
  color: #7ba68c;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.progress {
  color: #7ba68c;
  font-size: 34rpx;
  font-weight: 700;
}

.switch-theme-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 64rpx;
  margin: 22rpx 0 0;
  border: 1rpx solid rgba(123, 166, 140, 0.38);
  background: rgba(123, 166, 140, 0.12);
  color: #4e7a60;
  font-size: 25rpx;
  line-height: 64rpx;
}

.switch-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.72);
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 28rpx;
}

.slot-tap {
  position: relative;
  display: block;
}

.synthesize-btn {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  z-index: 4;
  width: 70rpx;
  height: 38rpx;
  margin: 0;
  padding: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.88);
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 38rpx;
}
