.album-page {
  min-height: 100vh;
  padding: 18rpx 16rpx 30rpx;
  background: #d7c09b;
  color: #4a2f17;
  font-family: "Comic Sans MS", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.album-page view,
.album-page text {
  font-weight: 900;
}

.book-shell {
  position: relative;
  height: 1510rpx;
  padding: 36rpx 26rpx 0 70rpx;
  overflow: hidden;
  border: 0;
  border-radius: 34rpx;
  background: transparent;
  box-shadow: 0 18rpx 36rpx rgba(54, 42, 30, 0.24);
}

.scrapbook-bg-img {
  position: absolute;
  top: 0;
  left: 50%;
  z-index: 0;
  width: 106%;
  height: auto;
  pointer-events: none;
  transform: translateX(-50%);
}

.book-ring {
  display: none;
}

.ring-a {
  top: 74rpx;
}

.ring-b {
  top: 360rpx;
}

.ring-c {
  bottom: 92rpx;
}

.hero-paper,
.reward-panel,
.filter-panel,
.empty,
.album-grid {
  position: relative;
  z-index: 2;
  margin-left: 0;
}

.hero-paper {
  padding: 18rpx 20rpx 10rpx;
  border: 0;
  border-radius: 24rpx;
  background: transparent;
  box-shadow: none;
}

.tape {
  display: none;
}

.tape-left {
  top: -12rpx;
  left: 34rpx;
  transform: rotate(-8deg);
}

.tape-right {
  top: -10rpx;
  right: 26rpx;
  background: rgba(248, 204, 145, 0.86);
  transform: rotate(8deg);
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.back-sticker {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff6d9;
  color: #7c5b2d;
  font-size: 58rpx;
  font-weight: 900;
  line-height: 48rpx;
  box-shadow: 0 7rpx 12rpx rgba(112, 82, 44, 0.14);
}

.theme-pill {
  min-width: 0;
  overflow: hidden;
  padding: 9rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 238, 189, 0.88);
  color: #896420;
  font-size: 24rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  text-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.92),
    0 5rpx 8rpx rgba(112, 82, 44, 0.16);
  white-space: nowrap;
}

.switch-theme-btn {
  display: flex;
  height: 54rpx;
  flex: none;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(188, 141, 76, 0.22);
  border-radius: 999rpx;
  background: rgba(255, 252, 244, 0.92);
  color: #8a6a42;
  font-size: 22rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.86);
}

.switch-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.75);
}

.title-row {
  display: flex;
  justify-content: center;
  margin-top: 0;
}

.title-cloud {
  position: relative;
  padding: 4rpx 34rpx 10rpx;
  color: #5c9961;
  font-size: 76rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1;
  text-shadow:
    0 5rpx 0 #fffaf0,
    5rpx 0 0 #fffaf0,
    -5rpx 0 0 #fffaf0,
    0 -5rpx 0 #fffaf0,
    0 10rpx 10rpx rgba(85, 120, 76, 0.18);
}

.title-cloud::after {
  position: absolute;
  right: 4rpx;
  bottom: 2rpx;
  color: #f6c55d;
  font-size: 30rpx;
  content: "★";
}

.progress-card {
  position: relative;
  display: grid;
  grid-template-columns: 166rpx 1fr 112rpx;
  gap: 16rpx;
  align-items: center;
  margin-top: 10rpx;
  padding: 12rpx 16rpx;
  border: 0;
  border-radius: 22rpx;
  background: rgba(255, 252, 244, 0.28);
}

.progress-label {
  color: #8a6a42;
  font-size: 23rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.8);
}

.progress {
  margin-top: 4rpx;
  color: #65a36d;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow:
    0 3rpx 0 rgba(255, 255, 255, 0.94),
    0 6rpx 9rpx rgba(91, 126, 85, 0.18);
}

.progress-hint {
  margin-top: 8rpx;
  color: #8a6a42;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.25;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.78);
}

.progress-track {
  position: relative;
  height: 28rpx;
  overflow: hidden;
  border: 3rpx solid rgba(213, 179, 119, 0.5);
  border-radius: 999rpx;
  background: #f4e3ba;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #80c879, #f4c95d);
}

.progress-star {
  position: absolute;
  top: 50%;
  left: 50%;
  display: flex;
  width: 42rpx;
  height: 42rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff4b8;
  color: #f1b824;
  font-size: 26rpx;
  transform: translate(-50%, -50%);
}

.reward-sticker {
  display: flex;
  min-height: 86rpx;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  border: 2rpx dashed rgba(123, 166, 140, 0.42);
  border-radius: 20rpx;
  background: rgba(223, 242, 255, 0.82);
  color: #557e68;
  font-size: 22rpx;
  font-weight: 900;
  text-align: center;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.78);
}

.reward-panel {
  margin-top: 8rpx;
  padding: 12rpx 16rpx 12rpx;
  border: 0;
  border-radius: 24rpx;
  background: rgba(255, 253, 244, 0.18);
  box-shadow: none;
}

.section-sticker {
  display: inline-flex;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #ffe1e0;
  color: #8d4d42;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 6rpx 10rpx rgba(124, 72, 53, 0.12);
}

.reward-subtitle {
  margin-top: 8rpx;
  color: #8a6a42;
  font-size: 22rpx;
  font-weight: 800;
}

.reward-list {
  width: 100%;
  margin-top: 10rpx;
  white-space: nowrap;
}

.reward-card {
  position: relative;
  display: inline-block;
  width: 118rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.reward-badge {
  position: absolute;
  top: -8rpx;
  left: -4rpx;
  z-index: 6;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #ff9e9e;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  box-shadow: 0 4rpx 8rpx rgba(142, 65, 55, 0.15);
}

.filter-panel {
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 244, 0.36);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 10rpx;
}

.rarity-row {
  margin-top: 12rpx;
}

.filter-btn {
  display: inline-flex;
  min-width: 104rpx;
  height: 50rpx;
  margin-right: 10rpx;
  padding: 0 22rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(123, 166, 140, 0.25);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #435c4d;
  font-size: 24rpx;
  font-weight: 900;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.86);
  vertical-align: top;
}

.filter-btn.active {
  border-color: rgba(123, 166, 140, 0.68);
  background: linear-gradient(180deg, #b5df8b, #87c76a);
  color: #fff;
  text-shadow: 0 2rpx 0 rgba(76, 119, 67, 0.22);
}

.rarity-btn {
  flex: 1;
  min-width: 0;
  margin-right: 0;
  padding: 0;
}

.empty {
  margin-top: 22rpx;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 244, 0.9);
  text-align: center;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #4a2f17;
  font-size: 30rpx;
  font-weight: 900;
}

.muted {
  color: #7d8b7f;
  font-size: 23rpx;
  font-weight: 800;
}

.album-grid {
  display: block;
  height: 680rpx;
  margin-top: 14rpx;
  padding: 14rpx;
  border: 0;
  border-radius: 26rpx;
  background: rgba(255, 253, 244, 0.24);
  box-sizing: border-box;
  overflow-x: hidden;
}

.album-grid-inner {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
  box-sizing: border-box;
  width: 100%;
  min-width: 0;
}

.slot-tap {
  position: relative;
  display: block;
  min-width: 0;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(247, 228, 190, 0.44);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.48);
}

.reward-card .size-small {
  height: 176rpx;
}

.slot-tap .size-small {
  height: 198rpx;
}

.slot-tap .placeholder,
.slot-tap .card-name,
.slot-tap .card-count,
.slot-tap .card-no,
.slot-tap .rarity-text {
  font-weight: 900;
  text-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.92),
    0 5rpx 8rpx rgba(91, 126, 85, 0.18);
}

.slot-tap .placeholder {
  color: #8f9f93;
  font-size: 31rpx;
}

.synthesize-btn {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  z-index: 4;
  display: flex;
  width: 72rpx;
  height: 40rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.92);
  color: #fff;
  font-size: 20rpx;
  font-weight: 900;
}

.scrapbook-tabs {
  position: absolute;
  right: 92rpx;
  left: 118rpx;
  top: 1254rpx;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28rpx;
  pointer-events: auto;
}

.tab-page {
  display: flex;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 18rpx;
  background: transparent;
  color: #6f4f25;
  font-family: "Comic Sans MS", "Arial Rounded MT Bold", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 31rpx;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow:
    0 3rpx 0 rgba(255, 247, 225, 0.96),
    3rpx 0 0 rgba(255, 247, 225, 0.9),
    -3rpx 0 0 rgba(255, 247, 225, 0.9),
    0 -3rpx 0 rgba(255, 247, 225, 0.9),
    0 7rpx 9rpx rgba(115, 83, 41, 0.2);
}

.tab-page.active {
  color: #3f8a55;
  text-shadow:
    0 3rpx 0 rgba(255, 255, 255, 0.96),
    3rpx 0 0 rgba(255, 255, 255, 0.9),
    -3rpx 0 0 rgba(255, 255, 255, 0.9),
    0 -3rpx 0 rgba(255, 255, 255, 0.9),
    0 8rpx 10rpx rgba(65, 118, 75, 0.22);
}
