.album-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.eyebrow {
  color: #7ba68c;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  margin-top: 8rpx;
  font-size: 44rpx;
  font-weight: 700;
}

.progress {
  color: #7ba68c;
  font-size: 34rpx;
  font-weight: 700;
}

.album-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 28rpx;
}

.slot {
  min-height: 250rpx;
  padding: 10rpx;
  text-align: center;
}

.slot-img {
  width: 100%;
  height: 156rpx;
}

.placeholder {
  display: flex;
  height: 156rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  background: #e9ece8;
  color: #98a39c;
  font-weight: 700;
}

.slot-name {
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 700;
}

.slot-meta {
  margin-top: 4rpx;
  color: #748078;
  font-size: 20rpx;
}

.locked {
  opacity: 0.72;
}
