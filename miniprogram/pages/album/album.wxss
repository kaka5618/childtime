.album-page {
  min-height: 100vh;
  padding: 18rpx 16rpx 28rpx;
  background: #d8c29f;
  color: #4f3822;
  font-family: "Arial Rounded MT Bold", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.album-page view,
.album-page text {
  font-weight: 900;
}

.book-shell {
  position: relative;
  min-height: 1510rpx;
  padding: 30rpx 30rpx 150rpx 78rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: linear-gradient(180deg, rgba(255, 251, 232, 0.72), rgba(255, 246, 219, 0.78));
  box-shadow: 0 18rpx 36rpx rgba(54, 42, 30, 0.22);
}

.scrapbook-bg-img {
  position: absolute;
  top: 0;
  left: 50%;
  z-index: 0;
  width: 106%;
  height: auto;
  opacity: 0.48;
  pointer-events: none;
  transform: translateX(-50%);
}

.book-ring,
.tape,
.reward-sticker {
  display: none;
}

.hero-paper,
.reward-panel,
.filter-panel,
.empty,
.album-grid {
  position: relative;
  z-index: 2;
}

.hero-paper {
  padding: 12rpx 16rpx 14rpx;
  border-radius: 26rpx;
  background: rgba(255, 252, 238, 0.86);
  box-shadow: inset 0 0 0 3rpx rgba(255, 255, 255, 0.72), 0 8rpx 18rpx rgba(109, 78, 42, 0.1);
}

.hero-top {
  display: grid;
  grid-template-columns: 62rpx 1fr auto;
  gap: 12rpx;
  align-items: center;
}

.back-sticker {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff4cf;
  box-shadow: 0 6rpx 12rpx rgba(112, 82, 44, 0.14);
  color: #7c5b2d;
  font-size: 58rpx;
  line-height: 48rpx;
}

.theme-pill {
  justify-self: center;
  max-width: 190rpx;
  overflow: hidden;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: #ffe9ad;
  color: #8a6122;
  font-size: 24rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.switch-theme-btn {
  display: flex;
  height: 52rpx;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(123, 166, 140, 0.22);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #607a65;
  font-size: 22rpx;
}

.switch-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.title-row {
  display: flex;
  justify-content: center;
  margin-top: 6rpx;
}

.title-cloud {
  color: #5a9a5f;
  font-size: 56rpx;
  line-height: 1;
  text-shadow:
    0 4rpx 0 #fffaf0,
    4rpx 0 0 #fffaf0,
    -4rpx 0 0 #fffaf0,
    0 -4rpx 0 #fffaf0;
}

.progress-card {
  display: grid;
  grid-template-columns: 130rpx 1fr;
  gap: 18rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 8rpx 8rpx 2rpx;
}

.progress-label {
  color: #7f6548;
  font-size: 22rpx;
}

.progress {
  margin-top: 2rpx;
  color: #5faa6b;
  font-size: 42rpx;
  line-height: 1;
  text-shadow: 0 3rpx 0 rgba(255, 255, 255, 0.9);
}

.progress-hint {
  display: none;
}

.progress-track {
  position: relative;
  height: 26rpx;
  overflow: hidden;
  border: 3rpx solid rgba(206, 170, 99, 0.45);
  border-radius: 999rpx;
  background: #f2dfb2;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #7cc879, #f5ca56);
}

.progress-star {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #fff1ad;
  color: #efb51f;
  font-size: 24rpx;
  line-height: 38rpx;
  text-align: center;
  transform: translate(-50%, -50%);
}

.reward-panel {
  margin-top: 14rpx;
  padding: 16rpx 16rpx 18rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 235, 0.93);
  box-shadow: inset 0 0 0 3rpx rgba(255, 255, 255, 0.76), 0 10rpx 20rpx rgba(98, 70, 36, 0.1);
}

.section-sticker {
  display: inline-flex;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: #ffe0e0;
  color: #8b5048;
  font-size: 27rpx;
}

.reward-subtitle {
  margin-top: 8rpx;
  color: #7c6348;
  font-size: 22rpx;
}

.reward-list {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.reward-card {
  position: relative;
  display: inline-block;
  width: 142rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

.reward-card .size-small {
  height: 224rpx;
  border-radius: 16rpx;
}

.reward-badge {
  position: absolute;
  top: -9rpx;
  left: -4rpx;
  z-index: 6;
  padding: 6rpx 13rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 999rpx;
  background: #ff8e9f;
  color: #fff;
  font-size: 19rpx;
  box-shadow: 0 5rpx 9rpx rgba(142, 65, 55, 0.14);
}

.filter-panel {
  margin-top: 14rpx;
  padding: 12rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 235, 0.88);
  box-shadow: inset 0 0 0 3rpx rgba(255, 255, 255, 0.56);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 10rpx;
}

.rarity-row {
  margin-top: 10rpx;
}

.filter-btn {
  display: inline-flex;
  min-width: 104rpx;
  height: 50rpx;
  margin-right: 10rpx;
  padding: 0 22rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(123, 166, 140, 0.24);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #435c4d;
  font-size: 24rpx;
  vertical-align: top;
}

.filter-btn.active {
  border-color: rgba(123, 166, 140, 0.68);
  background: linear-gradient(180deg, #b8df8f, #86c868);
  color: #fff;
}

.rarity-btn {
  flex: 1;
  min-width: 0;
  margin-right: 0;
  padding: 0;
}

.empty {
  margin-top: 16rpx;
  padding: 36rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 244, 0.92);
  text-align: center;
}

.empty-title {
  margin-bottom: 8rpx;
  color: #4f3822;
  font-size: 30rpx;
}

.muted {
  color: #6f7d70;
  font-size: 23rpx;
}

.album-grid {
  display: block;
  height: 640rpx;
  margin-top: 14rpx;
  padding: 16rpx;
  overflow-x: hidden;
  border-radius: 28rpx;
  background: rgba(255, 250, 235, 0.92);
  box-shadow: inset 0 0 0 3rpx rgba(255, 255, 255, 0.6);
  box-sizing: border-box;
}

.album-grid-inner {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.slot-tap {
  position: relative;
  display: block;
  min-width: 0;
  padding: 6rpx;
  border-radius: 18rpx;
  background: rgba(247, 228, 190, 0.34);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.48);
}

.slot-tap .size-small {
  height: 206rpx;
}

.slot-tap .placeholder {
  color: #879489;
  font-size: 31rpx;
}

.slot-tap .placeholder,
.slot-tap .card-name,
.slot-tap .card-count,
.slot-tap .card-no,
.slot-tap .rarity-text {
  font-weight: 900;
  text-shadow:
    0 2rpx 0 rgba(255, 255, 255, 0.92),
    0 5rpx 8rpx rgba(91, 126, 85, 0.16);
}

.synthesize-btn {
  position: absolute;
  right: 2rpx;
  bottom: 2rpx;
  z-index: 4;
  display: flex;
  width: 72rpx;
  height: 40rpx;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  background: rgba(123, 166, 140, 0.92);
  color: #fff;
  font-size: 20rpx;
}

.scrapbook-tabs {
  position: absolute;
  right: 88rpx;
  left: 112rpx;
  bottom: 108rpx;
  z-index: 20;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  height: 92rpx;
  pointer-events: auto;
}

.tab-page {
  display: flex;
  height: 100%;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.74);
  border-radius: 20rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)),
    #f4c985;
  box-shadow:
    0 8rpx 0 rgba(160, 112, 55, 0.45),
    0 14rpx 18rpx rgba(101, 72, 37, 0.14),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.22);
  color: #6f4f25;
  font-size: 29rpx;
  text-shadow:
    0 3rpx 0 rgba(255, 247, 225, 0.96),
    3rpx 0 0 rgba(255, 247, 225, 0.9),
    -3rpx 0 0 rgba(255, 247, 225, 0.9),
    0 -3rpx 0 rgba(255, 247, 225, 0.9);
}

.tab-page.active {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0)),
    #9fcf9f;
  box-shadow:
    0 8rpx 0 rgba(91, 131, 85, 0.46),
    0 14rpx 18rpx rgba(75, 105, 66, 0.14),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.24);
  color: #3f8a55;
}

.tab-page:nth-child(3) {
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0)),
    #efa799;
  box-shadow:
    0 8rpx 0 rgba(168, 91, 78, 0.42),
    0 14rpx 18rpx rgba(106, 67, 48, 0.14),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.22);
}
