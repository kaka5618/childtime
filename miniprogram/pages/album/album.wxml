<view class="page album-page">
  <view class="album-head">
    <view>
      <view class="eyebrow">{{activeThemeName}}</view>
      <view class="title">收藏本</view>
    </view>
    <view class="progress">{{collectionProgress.owned}}/{{collectionProgress.total}}</view>
  </view>

  <view class="progress-bar">
    <view class="progress-fill" style="width: {{collectionProgress.percent}}%;"></view>
  </view>

  <button class="switch-theme-btn" bindtap="goThemeSelect">
    <view class="switch-dot" style="background: {{activeThemeAccent}};"></view>
    <text>更换收集册</text>
  </button>

  <view wx:if="{{rewardVisible}}" class="reward-panel panel">
    <view class="reward-head">
      <view>
        <view class="reward-title">{{rewardTitle}}</view>
        <view class="muted">{{rewardSubtitle}}</view>
      </view>
    </view>
    <view class="reward-list">
      <view wx:for="{{rewardCards}}" wx:key="id" class="reward-card" bindtap="openRewardCard" data-id="{{item.id}}">
        <view class="reward-badge">{{item.badgeText}}</view>
        <card-face card="{{item}}" size="small" />
      </view>
    </view>
  </view>

  <view class="filter-panel">
    <view class="filter-row">
      <button wx:for="{{statusFilters}}" wx:key="key" class="filter-btn {{item.activeClass}}" data-filter="{{item.key}}" bindtap="changeStatusFilter">{{item.label}}</button>
    </view>
    <view class="filter-row rarity-row">
      <button wx:for="{{rarityFilters}}" wx:key="key" class="filter-btn rarity-btn {{item.activeClass}}" data-rarity="{{item.key}}" bindtap="changeRarityFilter">{{item.label}}</button>
    </view>
  </view>

  <view wx:if="{{emptyVisible}}" class="empty panel">
    <view class="empty-title">没有符合条件的卡</view>
    <view class="muted">换一个筛选条件试试。</view>
  </view>

  <view class="album-grid">
    <view wx:for="{{filteredCards}}" wx:key="id" class="slot-tap" bindtap="openCard" data-id="{{item.id}}" data-owned="{{item.owned}}">
      <card-face card="{{item}}" owned="{{item.owned}}" count="{{item.count}}" size="small" show-count />
      <button wx:if="{{item.canSynthesize}}" class="synthesize-btn" catchtap="synthesizeCard" data-id="{{item.id}}" data-name="{{item.name}}" data-hint="{{item.synthesisHint}}">合成</button>
    </view>
  </view>
</view>
