<view class="page album-page">
  <view class="album-head">
    <view>
      <view class="eyebrow">星梦泡泡</view>
      <view class="title">收藏本</view>
    </view>
    <view class="progress">{{ownedCount}}/50</view>
  </view>

  <view class="album-grid">
    <view wx:for="{{cards}}" wx:key="id" class="slot-tap" bindtap="openCard" data-id="{{item.id}}" data-owned="{{item.owned}}">
      <card-face card="{{item}}" owned="{{item.owned}}" count="{{item.count}}" size="small" show-count />
      <button wx:if="{{item.canSynthesize}}" class="synthesize-btn" catchtap="synthesizeCard" data-id="{{item.id}}" data-name="{{item.name}}">合成</button>
    </view>
  </view>
</view>
