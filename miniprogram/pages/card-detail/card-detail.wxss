.detail-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  padding: 42rpx 28rpx 54rpx;
  background:
    radial-gradient(circle at 22% 10%, rgba(255, 231, 142, 0.48), transparent 25%),
    radial-gradient(circle at 84% 22%, rgba(255, 178, 204, 0.32), transparent 28%),
    linear-gradient(180deg, #fff0bd 0%, #f6fbdf 52%, #dff0d2 100%);
  color: #55371e;
  font-family: "Arial Rounded MT Bold", "PingFang SC", "Microsoft YaHei", sans-serif;
}

.detail-page view,
.detail-page text {
  font-weight: 900;
}

.detail-bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.glow-a {
  top: 180rpx;
  left: -120rpx;
  width: 260rpx;
  height: 260rpx;
  background: rgba(255, 255, 255, 0.34);
}

.glow-b {
  right: -150rpx;
  bottom: 180rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(255, 212, 118, 0.26);
}

.detail-top,
.card-stage,
.info-sheet,
.action-bar {
  position: relative;
  z-index: 1;
}

.detail-top {
  display: grid;
  grid-template-columns: 62rpx 1fr 62rpx;
  align-items: center;
}

.back-btn {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.88);
  border-radius: 50%;
  background: #fff4cf;
  box-shadow: 0 7rpx 14rpx rgba(112, 82, 44, 0.15);
  color: #b5793c;
  font-size: 58rpx;
  line-height: 48rpx;
}

.top-copy {
  text-align: center;
}

.detail-kicker {
  display: inline-flex;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 229, 0.82);
  color: #74a069;
  font-size: 23rpx;
}

.detail-title {
  margin-top: 12rpx;
  color: #6a4121;
  font-size: 44rpx;
  line-height: 1.18;
  text-shadow:
    0 4rpx 0 #fff4d1,
    0 9rpx 14rpx rgba(128, 80, 31, 0.14);
}

.card-stage {
  margin-top: 28rpx;
  padding: 28rpx 18rpx 36rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 232, 0.76), rgba(255, 245, 213, 0.88));
  box-shadow:
    inset 0 0 0 4rpx rgba(255, 255, 255, 0.68),
    0 18rpx 36rpx rgba(103, 73, 36, 0.15);
}

.card-stage::after {
  position: absolute;
  right: 82rpx;
  bottom: 28rpx;
  left: 82rpx;
  height: 34rpx;
  border-radius: 50%;
  background: rgba(116, 80, 39, 0.16);
  content: "";
  filter: blur(2rpx);
}

.stage-spark {
  position: absolute;
  z-index: 3;
  color: #f4c44d;
  font-size: 34rpx;
  line-height: 1;
  text-shadow: 0 0 12rpx rgba(255, 226, 122, 0.8);
  pointer-events: none;
}

.spark-a {
  top: 34rpx;
  left: 44rpx;
}

.spark-b {
  top: 106rpx;
  right: 36rpx;
  color: #fff3a8;
}

.spark-c {
  left: 58rpx;
  bottom: 78rpx;
  color: #ff9fb3;
}

.card-stand {
  position: relative;
  z-index: 2;
  width: 520rpx;
  margin: 0 auto;
  border-radius: 34rpx;
  transform: rotate(-1deg);
  transform-origin: center;
}

.card-stand .size-large {
  height: 760rpx;
  border-radius: 28rpx;
  box-shadow:
    0 24rpx 34rpx rgba(78, 55, 31, 0.22),
    0 0 0 8rpx rgba(255, 255, 255, 0.62);
}

.info-sheet {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 30rpx;
  background: rgba(255, 252, 238, 0.92);
  box-shadow:
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.72),
    0 10rpx 20rpx rgba(103, 73, 36, 0.1);
}

.quick-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.stat-chip {
  min-width: 0;
  padding: 14rpx 8rpx 12rpx;
  border: 2rpx solid rgba(123, 166, 140, 0.18);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.74);
  text-align: center;
}

.rarity-chip {
  background: #fff0bd;
}

.stat-label {
  color: #7a705d;
  font-size: 21rpx;
}

.stat-value {
  margin-top: 6rpx;
  overflow: hidden;
  color: #4c7f56;
  font-size: 29rpx;
  line-height: 1.1;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-card {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(126, 182, 113, 0.14);
}

.status-badge {
  display: inline-flex;
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  background: #fff4cf;
  color: #9a6a2c;
  font-size: 21rpx;
}

.status-main {
  margin-top: 10rpx;
  color: #2f6b49;
  font-size: 31rpx;
}

.status-note {
  margin-top: 8rpx;
  color: #65756a;
  font-size: 24rpx;
  line-height: 1.45;
}

.action-bar {
  margin-top: 22rpx;
}

.action-btn {
  display: flex;
  width: 460rpx;
  height: 88rpx;
  margin: 18rpx auto 0;
  align-items: center;
  justify-content: center;
  border: 0;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 88rpx;
  letter-spacing: 0;
}

.action-btn::after {
  border: 0;
}

.synthesize-action {
  background: linear-gradient(180deg, #ffe27a, #f7b846);
  box-shadow:
    0 11rpx 0 #d28b31,
    0 18rpx 28rpx rgba(126, 77, 29, 0.2),
    inset 0 5rpx 0 rgba(255, 250, 215, 0.8);
  color: #744818;
}

.back-action {
  background: rgba(255, 252, 238, 0.9);
  box-shadow:
    0 8rpx 16rpx rgba(103, 73, 36, 0.12),
    inset 0 0 0 3rpx rgba(123, 166, 140, 0.2);
  color: #557865;
}

.btn-star {
  width: 54rpx;
  height: 54rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  background: #fff3bc;
  color: #f0a629;
  font-size: 33rpx;
  line-height: 54rpx;
  text-align: center;
}
