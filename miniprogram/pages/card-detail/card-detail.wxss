.detail-page {
  padding-bottom: 52rpx;
}

.info {
  margin-top: 24rpx;
  padding: 24rpx 28rpx;
}

.detail-title {
  font-size: 38rpx;
  font-weight: 800;
}

.detail-subtitle {
  margin-top: 8rpx;
  color: #748078;
  font-size: 25rpx;
  font-weight: 700;
}

.status-card {
  margin-top: 22rpx;
  margin-bottom: 10rpx;
  padding: 22rpx;
  border-radius: 8px;
  background: rgba(123, 166, 140, 0.12);
}

.status-main {
  color: #2f6b49;
  font-size: 30rpx;
  font-weight: 800;
}

.status-note {
  margin-top: 8rpx;
  color: #5f6f66;
  font-size: 24rpx;
  line-height: 1.45;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 14rpx 0;
  color: #3b2a12;
  font-weight: 700;
}

.info-row + .info-row {
  border-top: 1rpx solid rgba(35, 51, 43, 0.08);
}

.action-btn {
  margin-top: 22rpx;
}
