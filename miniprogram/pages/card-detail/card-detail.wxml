<view class="page detail-page" wx:if="{{card}}">
  <card-face card="{{card}}" size="large" />

  <view class="info panel">
    <view class="detail-title">{{card.name}}</view>
    <view class="detail-subtitle">{{card.no}} · {{card.rarity}}</view>

    <view class="status-card">
      <view class="status-main">{{synthesisTitle}}</view>
      <view class="status-note">{{synthesisNote}}</view>
    </view>

    <view class="info-row">
      <text>卡名</text>
      <text>{{card.name}}</text>
    </view>
    <view class="info-row">
      <text>编号</text>
      <text>{{card.no}}</text>
    </view>
    <view class="info-row">
      <text>稀有度</text>
      <text>{{card.rarity}}</text>
    </view>
    <view class="info-row">
      <text>拥有数量</text>
      <text>{{count}}</text>
    </view>
  </view>

  <button wx:if="{{canSynthesize}}" class="primary-btn action-btn" bindtap="synthesizeCard">合成卡包</button>
  <button class="secondary-btn action-btn" bindtap="goAlbum">返回收藏本</button>
</view>
