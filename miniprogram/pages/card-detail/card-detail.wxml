<view class="page detail-page {{detailClass}}" wx:if="{{card}}">
  <view class="detail-bg-glow glow-a"></view>
  <view class="detail-bg-glow glow-b"></view>
  <view class="detail-paper tape-a"></view>
  <view class="detail-paper tape-b"></view>

  <view class="detail-top">
    <view class="back-btn" bindtap="goAlbum">‹</view>
    <view class="top-copy">
      <view class="detail-kicker">{{obtainHint}}</view>
      <view class="detail-title">{{card.name}}</view>
    </view>
  </view>

  <view class="card-stage">
    <view class="rare-halo"></view>
    <view class="stage-spark spark-a">★</view>
    <view class="stage-spark spark-b">✦</view>
    <view class="stage-spark spark-c">★</view>
    <view class="card-stand">
      <card-face card="{{card}}" size="large" owned="{{owned}}"></card-face>
    </view>
  </view>

  <view class="info-sheet">
    <view class="quick-stats">
      <view class="stat-chip">
        <view class="stat-label">编号</view>
        <view class="stat-value">{{card.no}}</view>
      </view>
      <view class="stat-chip rarity-chip">
        <view class="stat-label">稀有度</view>
        <view class="stat-value">{{card.rarity}}</view>
      </view>
      <view class="stat-chip">
        <view class="stat-label">数量</view>
        <view class="stat-value">x{{count}}</view>
      </view>
    </view>

    <view class="status-card">
      <view class="status-badge">{{statusBadge}}</view>
      <view class="status-main">{{synthesisTitle}}</view>
      <view class="status-note">{{synthesisNote}}</view>
      <view wx:if="{{owned}}" class="synthesis-progress">
        <view class="progress-card active-card">收藏 x{{count}}</view>
        <view class="progress-arrow">→</view>
        <view class="progress-card">消耗 x{{consumeCount}}</view>
        <view class="progress-arrow">→</view>
        <view class="progress-card keep-card">保留 x{{remainingAfterSynthesis}}</view>
      </view>
      <view wx:if="{{canSynthesize}}" class="magic-box">
        <view class="magic-light"></view>
        <view class="magic-lid"></view>
        <view class="magic-body">
          <view class="magic-star">★</view>
        </view>
        <view class="magic-copy">重复卡放进魔法盒，变成新卡包</view>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <button wx:if="{{canSynthesize}}" class="action-btn synthesize-action" bindtap="synthesizeCard">
      <view class="btn-star">★</view>
      <text>放进魔法盒</text>
    </button>
    <button class="action-btn back-action" bindtap="goAlbum">
      <text>返回收藏本</text>
    </button>
  </view>
</view>
