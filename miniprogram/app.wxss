page {
  min-height: 100vh;
  background: #faf6f0;
  color: #23332b;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

button {
  border-radius: 8px;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.primary-btn {
  background: #7ba68c;
  color: #fff;
}

.secondary-btn {
  background: #f5c26b;
  color: #3b2a12;
}

.muted {
  color: #748078;
}

.panel {
  background: #fffaf4;
  border: 1rpx solid rgba(35, 51, 43, 0.08);
  border-radius: 8px;
}
